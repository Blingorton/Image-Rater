        tip(tk.Button(abar, text="Go", command=lambda: self._navigate(self._path_var.get()),
                  bg=BG_BTN, fg=FG_WHITE, relief=tk.FLAT, padx=10, pady=4,
                  font=("Segoe UI",9), cursor="hand2"), "Navigate to path").pack(side=tk.LEFT, padx=4)

        body = tk.Frame(self, bg=BG_DARK); body.pack(fill=tk.BOTH, expand=True)
