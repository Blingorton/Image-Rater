        s["remember_zoom"]  = self._v_remember_zoom.get()
        # Appearance
        for key, var in (
            ("lbar_width",      self._v_lbar_width),
            ("rbar_h_default",  self._v_rbar_h_def),
            ("tb_thumb_size",   self._v_tb_size_def),
            ("tb_bar_h",        self._v_tb_bar_h),
            ("tb_label_h_user", self._v_tb_label_h),
            ("tb_border_user",  self._v_tb_border),
            ("tb_pad_user",     self._v_tb_pad),
        ):
            try: s[key] = int(var.get())
            except ValueError: pass
        # Hotkeys
        for hk_key, var in self._hk_vars.items():
            s[hk_key] = var.get()
        # Folders
        s["default_folder"]  = self._v_default_folder.get()
        s["move_dest_folder"] = self._v_move_dest.get()
        s["sort_method"]      = self._v_sort.get()
        save_settings(s)
        self._status.config(text="Saved! Hotkeys take effect on next launch.")
        self.after(1200, self.destroy)

