class CommentDialog(tk.Toplevel):
    """Persistent PNG comment viewer — stays open and tracks current image."""
    def __init__(self, parent, filepath, settings=None, on_close=None):
        super().__init__(parent)
        self.configure(bg=BG_DARK)
        self.transient(parent)
        self._settings  = settings or {}
        self._on_close  = on_close
        restore_popup_geom(self, self._settings, "comment", "640x400")
        bind_popup_geom(self, self._settings, "comment")
        # Text area
        self._txt = tk.Text(self, bg="#252525", fg=FG_INFO, font=("Segoe UI",9),
                            relief=tk.FLAT, wrap=tk.WORD, padx=8, pady=8)
        self._txt.pack(fill=tk.BOTH, expand=True, padx=8, pady=(8,0))
        bot = tk.Frame(self, bg=BG_DARK); bot.pack(fill=tk.X, pady=6)
        tk.Button(bot, text="Copy to Clipboard", command=self._copy,
                  bg=BG_BTN, fg=FG_WHITE, relief=tk.FLAT, font=("Segoe UI",9),
                  padx=10, pady=4, cursor="hand2").pack(side=tk.LEFT, padx=10)
        tk.Button(bot, text="Close", command=self._close,
                  bg=BG_BTN, fg=FG_DIM, relief=tk.FLAT, font=("Segoe UI",9),
                  padx=10, pady=4, cursor="hand2").pack(side=tk.RIGHT, padx=10)
        self.protocol("WM_DELETE_WINDOW", self._close)
        self.update_image(filepath)

    def update_image(self, filepath):
        """Switch to a different image, refreshing title and content."""
        self._filepath = filepath
        self.title(f"Comment – {os.path.basename(filepath)}")
        comment = get_png_comment(filepath)
        self._txt.config(state=tk.NORMAL)
        self._txt.delete("1.0", tk.END)
        if comment:
            self._txt.insert("1.0", comment)
        else:
            self._txt.insert("1.0", "(no comment metadata)")
            self._txt.config(fg=FG_DIM)
            self.after(1, lambda: self._txt.config(fg=FG_INFO))

    def _copy(self):
        self.clipboard_clear()
        self.clipboard_append(self._txt.get("1.0", tk.END))

    def _close(self):
        if self._on_close:
            try: self._on_close()
            except Exception: pass
        self.destroy()

def show_comment_dialog(parent, filepath, settings=None, on_close=None):
    """Open (or re-use) a CommentDialog. Returns the dialog instance."""
    dlg = CommentDialog(parent, filepath, settings=settings, on_close=on_close)
    return dlg

# ── Sort helpers ─────────────────────────────────────────────────────────────

def _run_sort_quick(folder, settings):
    """Run keyword sort using saved settings rules with no UI. Returns (moved, errors)."""
    saved = settings.get("sort_rows", [])
    rules = [(row[0].strip(), (row[1].strip() or row[0].strip()))
             for row in saved if row[0].strip()]
    if not rules: return 0, 0
    moved = errors = 0
    for fname in [f for f in os.listdir(folder) if f.lower().endswith(".png")]:
        fpath = os.path.join(folder, fname)
        comment = get_png_comment(fpath)
        for kw, fld in rules:
            if kw.lower() in comment.lower():
                dest = os.path.join(folder, fld)
                os.makedirs(dest, exist_ok=True)
                try: shutil.move(fpath, os.path.join(dest, fname)); moved += 1
                except Exception: errors += 1
                break
    return moved, errors

