class SubfolderDialog(tk.Toplevel):
    def __init__(self, parent, folder, images, jump_cb, settings=None,
                 jump_to_idx_cb=None):
        """
        jump_cb(subdir)       — jump to first image in subdir
        jump_to_idx_cb(idx)   — jump to image at absolute index in images list
        """
        super().__init__(parent)
        self.title("Subfolders"); self.configure(bg=BG_DARK)
        self.resizable(True, True); self.transient(parent)
        restore_popup_geom(self, settings or {}, "subfolder", "480x520")
        if settings: bind_popup_geom(self, settings, "subfolder")

        self._images         = images
        self._jump_to_idx_cb = jump_to_idx_cb

        # Build ordered subdir list (preserving order of first appearance)
        subdirs = []; seen = set()
        for rel in images:
            d = os.path.dirname(rel)
            if d not in seen: seen.add(d); subdirs.append(d)
        # subdirs[0] may be "" (root); include it for per-folder buttons
        # but don't show it as a clickable subfolder name

        # ── helpers ───────────────────────────────────────────────────────────

        def _subdir_images(subdir):
            """Return (global_index, rel) pairs for images in subdir."""
            return [(i, r) for i, r in enumerate(images)
                    if os.path.dirname(r) == subdir]

        def _last_seen_idx(img_pairs):
            """
            'Last seen' = end of the longest contiguous run of prefixed images
            starting from the first image in img_pairs.
            Walk forward while each image has ANY prefix; return the index of
            the last one before the first gap (or unrated image).
            Example: -1,-2,__3,-4,-5,_6,_7,_8,9,10,__11 → _8 (index 7 globally)
            """
            result = None
            for gi, rel in img_pairs:
                base = os.path.basename(rel)
                if is_unrated(base):   # no prefix at all — stop here
                    break
                result = gi            # this one is prefixed; keep advancing
            return result

        def _last_rated_idx(img_pairs):
            """
            'Last rated' = lowest index that has a non-'-' rating prefix.
            """
            for gi, rel in img_pairs:
                base = os.path.basename(rel)
                if get_rating_from_name(base) is not None:
                    return gi
            return None

        def _safe_contiguous_idx(img_pairs):
            """
            Highest index N such that images[0..N] in img_pairs all have any prefix.
            If the very first is unrated, returns its index (jump to it).
            """
            result = img_pairs[0][0] if img_pairs else None
            for gi, rel in img_pairs:
                base = os.path.basename(rel)
                if is_unrated(base):
                    return gi   # first gap — jump here
                result = gi
            return result

        def _do_jump_global(target_idx, img_pairs):
            """Perform jump with gap-warning for 'last rated' mode."""
            # Check for any truly-unrated image before target in this scope
            gap_gi = None
            for gi, rel in img_pairs:
                if gi >= target_idx: break
                if is_unrated(os.path.basename(rel)):
                    gap_gi = gi; break

            if gap_gi is not None:
                safe_gi   = _safe_contiguous_idx(img_pairs)
                target_nm = os.path.basename(images[target_idx])
                safe_nm   = os.path.basename(images[safe_gi])
                ans = messagebox.askquestion(
                    "Gap Detected",
                    f"Warning: #{gap_gi+1} ({os.path.basename(images[gap_gi])}) "
                    f"has no prefix and may not have been viewed yet.\n\n"
                    f"Yes → jump to target #{target_idx+1} ({target_nm})\n"
                    f"No  → jump to last contiguous #{safe_gi+1} ({safe_nm})",
                    parent=self)
                if ans == "no":
                    self.destroy()
                    jump_to_idx_cb(safe_gi); return

            self.destroy()
            jump_to_idx_cb(target_idx)

        def _btn_last_seen(img_pairs):
            idx = _last_seen_idx(img_pairs)
            if idx is None:
                messagebox.showinfo("Not Found",
                    "No prefixed images found in this scope.", parent=self); return
            self.destroy(); jump_to_idx_cb(idx)

        def _btn_last_rated(img_pairs):
            idx = _last_rated_idx(img_pairs)
            if idx is None:
                messagebox.showinfo("Not Found",
                    "No rated images found in this scope.", parent=self); return
            _do_jump_global(idx, img_pairs)

        # ── global buttons (all images) ───────────────────────────────────────
        tk.Label(self, text="Jump to subfolder:", bg=BG_DARK, fg=FG_INFO,
                 font=("Segoe UI",9,"bold")).pack(padx=10, pady=(10,2), anchor=tk.W)

        if jump_to_idx_cb:
