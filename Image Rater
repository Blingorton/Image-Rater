            icon = tk.Label(cell, text="📁", bg="#383838", fg="#f0c040", font=("Segoe UI",32))
            icon.place(x=0, y=P, width=cell_w, height=T)
            short = dname if len(dname)<=13 else dname[:10]+"…"
            tk.Label(cell, text=short, bg="#383838", fg=FG_INFO, font=("Segoe UI",7),
                     wraplength=cell_w-4).place(x=2, y=T+P, width=cell_w-4)
            for w in (cell, icon):
                w.bind("<Button-1>", lambda e,d=dname: self._navigate(os.path.join(self.current_dir,d)))
            self._cells.append((None, None, True))
        for idx, fname in enumerate(self._png_files):
            fpath = os.path.join(path, fname)
            cell  = tk.Frame(self._grid, bg="#2a2a2a", width=cell_w, height=cell_h, cursor="hand2")
            cell.pack_propagate(False)
            img_lbl = tk.Label(cell, bg="#2a2a2a", text="…", fg=FG_DIM)
            img_lbl.place(x=P, y=P, width=T, height=T)
            short = fname if len(fname)<=13 else fname[:10]+"…"
            tk.Label(cell, text=short, bg="#2a2a2a", fg=FG_INFO, font=("Segoe UI",7),
                     wraplength=cell_w-4).place(x=2, y=T+P, width=cell_w-4)
            for w in (cell, img_lbl):
                w.bind("<Button-1>", lambda e,i=idx: self._pick(i))
            self._cells.append((img_lbl, fpath, False))
            # Submit load job
            if fpath not in self._pil_cache and fpath not in self._loading:
                self._loading.add(fpath)
                self._executor.submit(self._load_worker, fpath)
        self.after(60, self._reflow)

    def _load_worker(self, fpath):
        if self._closed: return
        try:
            pil = Image.open(fpath); pil.load()
            thumb = pil.copy(); thumb.thumbnail((self.THUMB, self.THUMB), Image.BILINEAR)
            self._result_q.put(("ok", fpath, thumb))
        except Exception:
            self._result_q.put(("err", fpath, None))

    def _spin(self):
        """Animate the spinner arc while thumbnails are loading."""
        if self._closed: return
        if self._loading:
            self._spinner_angle = (self._spinner_angle - 24) % 360
            self._spinner_canvas.itemconfig(
                self._spinner_arc,
                start=self._spinner_angle,
                extent=270,
                outline="#f0c040"
            )
        else:
            # Idle: dim complete circle, no gap
            self._spinner_canvas.itemconfig(
                self._spinner_arc,
                start=90, extent=359, outline="#444444"
            )
        self._spinner_job = self.after(50, self._spin)

    def _drain_results(self):
        if self._closed: return
        for _ in range(20):
            try:
                status, fpath, thumb = self._result_q.get_nowait()
            except Exception: break
            self._loading.discard(fpath)
            if status == "ok":
                ph = ImageTk.PhotoImage(thumb)
                self._ph_cache[fpath] = ph
                # Find widget
                for img_lbl, fp, is_dir in self._cells:
                    if fp == fpath and img_lbl and img_lbl.winfo_exists():
                        img_lbl.config(image=ph, text=""); break
        self.after(20, self._drain_results)

    def _reflow(self):
        cw = self._canvas.winfo_width() or 860
        cell_w = self.THUMB + self.PAD*2 + 4
        cols   = max(1, cw // cell_w)
        for idx,child in enumerate(self._grid.winfo_children()):
            r,c = divmod(idx, cols)
            child.grid(row=r, column=c, padx=self.PAD, pady=self.PAD)
        self._canvas.itemconfig(self._cw, width=cw)
        self._canvas.configure(scrollregion=self._canvas.bbox("all"))

    def _go_up(self):
        p = os.path.dirname(self.current_dir)
        if p != self.current_dir: self._navigate(p)

    def _pick(self, idx):
        self.result_folder = self.current_dir
        self.result_index  = idx
        self.result_file   = self._png_files[idx] if 0 <= idx < len(self._png_files) else None
        self._closed = True; self.destroy()

    def _open_folder(self):
        self.result_folder = self.current_dir
        self.result_index  = 0
        self.result_file   = None
        self._closed = True; self.destroy()

    def _cancel(self):
        self.result_folder = None
        self.result_file   = None
        self._closed = True
        if self._spinner_job:
            try: self.after_cancel(self._spinner_job)
            except Exception: pass
        self.destroy()

# ── Thumbnail Browser ─────────────────────────────────────────────────────────

class ThumbnailBrowser(tk.Toplevel):
    SEL_COLOR  = "#f0c040"
    WORKERS    = 8
    PREFETCH   = 3
    HEADER_H   = 22   # subfolder header row height

    def __init__(self, parent, folder, images, settings,
                 jump_cb=None, rename_cb=None, initial_sel=None):
        super().__init__(parent)
        self.title("Thumbnail Browser")
        self.configure(bg=BG_DARK)
        # NOT transient so main viewer can be on top independently

        self._parent      = parent
        self.folder       = folder
        self._all_images  = list(images)   # preserve order from caller
        self._images      = list(self._all_images)
        self._selected    = set()
        self._last_sel    = None
        self._thumb_size  = settings.get("tb_thumb_size", TB_SIZE_DEFAULT)
        self._rating_buttons = {}
        self._settings    = settings
        self._resize_job  = None
        self._jump_cb     = jump_cb
        self._rename_cb   = rename_cb
        self._sort_method = settings.get("tb_sort", "Name")
        self._geom_job    = None
        self._tb_flat     = settings.get("tb_flat", False)
        self._tb_bar_left = settings.get("tb_bar_left", False)

        # Virtual canvas layout
        self._cols       = 1
        self._cell_w     = 1
        self._cell_h     = 1
        self._total_h    = 0
        # Rows list: each entry is either ("img", idx) or ("hdr", subdir_name)
        self._rows_list  = []

        self._pil_cache  = {}
        self._ph_cache   = {}
        self._loading    = set()
        self._executor   = ThreadPoolExecutor(max_workers=self.WORKERS)
        self._result_q   = queue.Queue()
        self._closed     = False
        self._row_items  = {}   # row_num -> [canvas_item_ids]
        self._row_indices = {}   # row_num -> [img_idx, ...]

        geom = settings.get("tb_geometry")
        if geom: self.geometry(geom)
        else:    self.state("zoomed")

        self._build_ui()
        self.protocol("WM_DELETE_WINDOW", self._on_close)
        self.bind("<Configure>", self._save_geom_debounced)

        self.after(80, lambda: self._full_refresh(scroll_to=initial_sel))
        self.after(30, self._drain_results)

        # Mouse buttons
        for btn_num in (4,5,6,7,8,9):
            try: self._canvas.bind(f"<Button-{btn_num}>",
                                   lambda e,n=btn_num: self._tb_extra_btn(e,n))
            except Exception: pass

    def _tb_extra_btn(self, e, num):
        if num in (4, 8): self._tb_mouse5()
        elif num in (5, 9): self._tb_mouse4()

    def _tb_mouse4(self):
        if not self._last_sel: return
        r = get_rating_from_name(self._last_sel)
        self._rate_selected_all(1 if r is None else r+1)

    def _tb_mouse5(self):
        if not self._last_sel: return
        r = get_rating_from_name(self._last_sel)
        self._rate_selected_all(0 if r is None else max(0, r-1))

    # ── Geometry save ─────────────────────────────────────────────────────────

    def _save_geom_debounced(self, e=None):
        if self._geom_job: self.after_cancel(self._geom_job)
        self._geom_job = self.after(500, self._save_geom)

    def _save_geom(self):
        try:
            self._settings["tb_geometry"]   = self.geometry()
            self._settings["tb_thumb_size"] = self._thumb_size
            self._settings["tb_sort"]       = self._sort_method
            self._settings["tb_flat"]       = self._tb_flat
            self._settings["tb_bar_left"]   = self._tb_bar_left
            self._settings["tb_bar_h"]      = self._tb_bar_h
            save_settings(self._settings)
        except Exception: pass

    def _on_close(self):
        self._closed = True
        self._executor.shutdown(wait=False)
        self._save_geom()
        self.destroy()

    # ── UI ────────────────────────────────────────────────────────────────────

    def _build_ui(self):
        # Outer container: toolbar + canvas, direction depends on _tb_bar_left
        self._outer = tk.Frame(self, bg=BG_DARK)
        self._outer.pack(fill=tk.BOTH, expand=True)
        self._tbar_frame = None
        self._canvas_frame = None
        self._canvas = None
        self._vsb    = None
        self._rebuild_layout()

    def _rebuild_layout(self):
        # Destroy existing children of _outer
        for w in self._outer.winfo_children(): w.destroy()
        self._rating_buttons.clear()

        if self._tb_bar_left:
            self._tbar_frame = tk.Frame(self._outer, bg=BG_PANEL, padx=4)
            self._tbar_frame.pack(side=tk.LEFT, fill=tk.Y)
            self._canvas_frame = tk.Frame(self._outer, bg=BG_DARK)
            self._canvas_frame.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)
            self._tb_handle = None
        else:
            self._tb_container = tk.Frame(self._outer, bg=BG_PANEL)
            self._tb_container.pack(side=tk.BOTTOM, fill=tk.X)
            self._tb_handle = tk.Frame(self._tb_container, bg="#555555", height=5,
                                        cursor="sb_v_double_arrow")
            self._tb_handle.pack(side=tk.TOP, fill=tk.X)
            self._tb_handle.bind("<ButtonPress-1>",   self._tb_grab_start)
            self._tb_handle.bind("<B1-Motion>",        self._tb_grab_drag)
            self._tb_handle.bind("<ButtonRelease-1>", self._tb_grab_end)
            self._tbar_frame = tk.Frame(self._tb_container, bg=BG_PANEL, pady=4)
            self._tbar_frame.pack(side=tk.TOP, fill=tk.X)
            self._canvas_frame = tk.Frame(self._outer, bg=BG_DARK)
            self._canvas_frame.pack(side=tk.TOP, fill=tk.BOTH, expand=True)

        self._tb_bg_frames = []   # populated by _build_toolbar
        self._build_toolbar()
        self._build_canvas()

    def _build_toolbar(self):
        tbar = self._tbar_frame
        self._tb_bg_frames.append(tbar)   # tbar itself tracks bar color
        BOX  = "#333333"   # dark grey button box color
        BPAD = 3           # box padding around buttons

        def boxed_btn(text, cmd, btn_bg=BG_BTN, btn_fg=FG_WHITE, box_bg=BOX, tt=""):
            """Button inside a colored box frame."""
            if self._tb_bar_left:
                box = tk.Frame(tbar, bg=box_bg, padx=BPAD, pady=2)
                box.pack(side=tk.TOP, padx=3, pady=1, fill=tk.X)
                b = tk.Button(box, text=text, command=cmd, bg=btn_bg, fg=btn_fg,
                              relief=tk.FLAT, font=("Segoe UI",9),
                              padx=3, pady=1, cursor="hand2")
            else:
                box = tk.Frame(tbar, bg=box_bg, padx=BPAD, pady=BPAD)
                box.pack(side=tk.LEFT, padx=2, pady=3)
                b = tk.Button(box, text=text, command=cmd, bg=btn_bg, fg=btn_fg,
                              relief=tk.FLAT, font=("Segoe UI",11),
                              padx=4, pady=2, cursor="hand2")
            b.pack(fill=tk.X if self._tb_bar_left else tk.NONE)
            if tt: tip(b, tt)
            return b

        boxed_btn("📂", self._open_folder, tt="Open folder")
        boxed_btn("🗑", self._delete_trash, btn_bg="#662222", box_bg="#441111", tt="Delete all rating-0 files")
        boxed_btn("⚙", self._open_sort_dialog, btn_bg="#444466", box_bg="#2a2a44", tt="Sort files by keyword into subfolders")
        boxed_btn("🗂", self._open_explorer_sel, tt="Open selected file in Windows Explorer")
        boxed_btn("↕", self._pick_sort, tt="Change sort order")
        self._flat_box_btn = boxed_btn(
            "⊟" if self._tb_flat else "⊞",
            self._toggle_tb_flat,
            btn_bg="#336633" if self._tb_flat else BG_BTN,
            box_bg="#224422" if self._tb_flat else BOX,
            tt="Toggle flat/grouped view")
        boxed_btn("📁⚙", self._tb_subfolder_jump, tt="Jump to subfolder")
        boxed_btn("📝", self._show_comment, tt="Show PNG comment metadata")
        boxed_btn("A:-", self._rename_unrated_popup, tt="Add/remove '-' prefix on unrated images")
        boxed_btn("→📁", self._move_files, tt="Move all files to another folder")
        boxed_btn("🔄", self._refresh, tt="Refresh folder")
        boxed_btn("⚙S", self._open_settings, tt="Open settings")
        self._bar_side_btn = boxed_btn(
            "◧" if self._tb_bar_left else "▬",
            self._toggle_bar_side, tt="Toggle toolbar left/bottom")

        # Rating buttons — box color matches rating color (darkened).
        # Show 0 through max(5, current+1) so rating above 5 is always reachable.
        self._rating_buttons = {}
        _cur_sel_r = get_rating_from_name(self._last_sel) if self._last_sel else None
        _tb_max_r  = max(5, (_cur_sel_r or 0) + 1)
        for i in range(_tb_max_r + 1):
            rc    = rating_color(i)
            box_c = _darken(rc, 0.55)
            if self._tb_bar_left:
                box = tk.Frame(tbar, bg=box_c, padx=BPAD, pady=2)
                box.pack(side=tk.TOP, padx=3, pady=1, fill=tk.X)
                b = tk.Button(box, text=str(i), bg=rc, fg=_rating_fg(i),
                              relief=tk.FLAT, font=("Segoe UI",9,"bold"),
                              command=lambda r=i: self._rate_selected_all(r),
                              cursor="hand2", pady=1)
                b.pack(fill=tk.X)
            else:
                box = tk.Frame(tbar, bg=box_c, padx=BPAD, pady=BPAD)
                box.pack(side=tk.LEFT, padx=2, pady=3)
                b = tk.Button(box, text=str(i), bg=rc, fg=_rating_fg(i),
                              relief=tk.FLAT, font=("Segoe UI",13,"bold"),
                              command=lambda r=i: self._rate_selected_all(r),
                              cursor="hand2", width=3, pady=2)
                b.pack()
            tip(b, f"Rate selected image(s) as {i}")
            self._rating_buttons[i] = b

        if not self._tb_bar_left:
            # Right side: size buttons + info panel
            # Size adjust buttons in dark boxes
            right = tk.Frame(tbar, bg=BG_PANEL); right.pack(side=tk.RIGHT, pady=3)
            self._tb_bg_frames.append(right)   # right frame tracks bar color
            for sym, delta in (("+", +20), ("−", -20)):
                box = tk.Frame(right, bg=BOX, padx=BPAD, pady=BPAD)
                box.pack(side=tk.RIGHT, padx=2)
                tip(tk.Button(box, text=sym,
                          command=lambda d=delta: self._resize_thumbs(d),
                          bg=BG_BTN, fg=FG_WHITE, relief=tk.FLAT, font=("Segoe UI",11),
                          padx=6, pady=2, cursor="hand2"),
                    "Larger thumbnails" if delta > 0 else "Smaller thumbnails").pack()

            # Info panel — dark grey box, 3-column layout
            info_box = tk.Frame(tbar, bg="#222222", padx=6, pady=4)
            info_box.pack(side=tk.RIGHT, padx=6, pady=3)
            # Col 1: global idx + subfolder idx
            col1 = tk.Frame(info_box, bg="#222222"); col1.pack(side=tk.LEFT, padx=(0,8))
            self._tb_info_idx = tk.Label(col1, text="", bg="#222222", fg=FG_RATING,
                                          font=("Segoe UI",8,"bold"))
            self._tb_info_idx.pack(anchor=tk.W)
            self._tb_info_sub = tk.Label(col1, text="", bg="#222222", fg=FG_RATING,
                                          font=("Segoe UI",7))
            self._tb_info_sub.pack(anchor=tk.W)
            # Col 2: subfolder name + resolution
            col2 = tk.Frame(info_box, bg="#222222"); col2.pack(side=tk.LEFT, padx=(0,8))
            self._tb_info_subname = tk.Label(col2, text="", bg="#222222", fg=FG_RATING,
                                              font=("Segoe UI",7))
            self._tb_info_subname.pack(anchor=tk.W)
            self._tb_info_res = tk.Label(col2, text="", bg="#222222", fg="#aaaaaa",
                                          font=("Segoe UI",7))
            self._tb_info_res.pack(anchor=tk.W)
            # Col 3: star rating — fixed size frame so toolbar height is stable
            col3 = tk.Frame(info_box, bg="#222222", width=64, height=34)
            col3.pack(side=tk.LEFT); col3.pack_propagate(False)
            self._tb_info_star = tk.Label(col3, text="", bg="#222222", fg=FG_RATING,
                                           font=("Segoe UI",11,"bold"))
            self._tb_info_star.place(relx=0.5, rely=0.5, anchor=tk.CENTER)
        else:
            # Vertical (left) bar layout:
            # Info box positioned between toggle-bar button and rating buttons.
            # All buttons already packed above (side=TOP). Now pack info box
            # before rating buttons by inserting it here — rating buttons
            # are packed AFTER this block in the shared rating loop above,
            # but since we're in the else branch that runs AFTER the rating loop,
            # we need to re-order. Solution: use a container frame approach.
            # The rating buttons were already packed into tbar; we need the info box
            # to appear above them visually. Since pack goes top-down in order of
            # .pack() calls, we must build the info box BEFORE rating buttons.
            # But the shared code already packed rating buttons. So we use
            # tbar.pack_slaves() reordering via lower()/raise() — but tkinter
            # doesn't support that directly for pack.
            #
            # Best solution: don't pack rating buttons in shared loop for left mode;
            # pack them here after the info box. We'll detect left mode in the
            # rating loop via a flag.
            #
            # Since this else block runs AFTER the rating loop has already packed
            # buttons into tbar, we detach and reattach them after the info box.
            # Collect the rating button container frames (they were the last packed).
            rating_boxes = list(tbar.winfo_children())[-6:]   # last 6 are rating boxes
            for rb in rating_boxes: rb.pack_forget()

            # Info box — compact, fits in narrow vertical bar
            info_box = tk.Frame(tbar, bg="#222222", padx=3, pady=3)
            info_box.pack(side=tk.TOP, padx=3, pady=(4,2), fill=tk.X)
            self._tb_info_idx = tk.Label(info_box, text="", bg="#222222", fg=FG_RATING,
                                          font=("Segoe UI",7,"bold"), wraplength=58, justify=tk.CENTER)
            self._tb_info_idx.pack(fill=tk.X)
            self._tb_info_sub = tk.Label(info_box, text="", bg="#222222", fg=FG_RATING,
                                          font=("Segoe UI",6), wraplength=58, justify=tk.CENTER)
            self._tb_info_sub.pack(fill=tk.X)
            self._tb_info_subname = tk.Label(info_box, text="", bg="#222222", fg=FG_RATING,
                                              font=("Segoe UI",6), wraplength=58, justify=tk.CENTER)
            self._tb_info_subname.pack(fill=tk.X)
            self._tb_info_res = tk.Label(info_box, text="", bg="#222222", fg="#aaaaaa",
                                          font=("Segoe UI",6), wraplength=58, justify=tk.CENTER)
            self._tb_info_res.pack(fill=tk.X)
            self._tb_info_star = tk.Label(info_box, text="", bg="#222222", fg=FG_RATING,
                                           font=("Segoe UI",7,"bold"), wraplength=58, justify=tk.CENTER)
            self._tb_info_star.pack(fill=tk.X)

            # Re-pack rating buttons below info box
            for rb in rating_boxes:
                rb.pack(side=tk.TOP, padx=3, pady=1, fill=tk.X)

            # Size buttons at bottom
            for sym, delta in (("−", -20), ("+", +20)):
                box = tk.Frame(tbar, bg=BOX, padx=BPAD, pady=BPAD)
                box.pack(side=tk.TOP, padx=3, pady=1, fill=tk.X)
                tip(tk.Button(box, text=sym,
                          command=lambda d=delta: self._resize_thumbs(d),
                          bg=BG_BTN, fg=FG_WHITE, relief=tk.FLAT, font=("Segoe UI",9),
                          padx=2, pady=1, cursor="hand2"),
                    "Larger thumbnails" if delta > 0 else "Smaller thumbnails").pack(fill=tk.X)

    def _build_canvas(self):
        cf = self._canvas_frame
        self._vsb = tk.Scrollbar(cf, orient=tk.VERTICAL, bg=BG_PANEL, troughcolor=BG_DARK)
        self._vsb.pack(side=tk.RIGHT, fill=tk.Y)
        self._canvas = tk.Canvas(cf, bg=BG_DARK, highlightthickness=0,
                                  yscrollcommand=self._vsb.set)
        self._canvas.pack(fill=tk.BOTH, expand=True)
        self._vsb.config(command=self._on_vscroll)

        self._canvas.bind("<Configure>",        self._on_canvas_configure)
        self.bind("<MouseWheel>",                self._on_scroll)
        self._canvas.bind("<Button-1>",          self._on_canvas_click)
        self._canvas.bind("<Double-Button-1>",   self._on_canvas_dbl)
        self._canvas.bind("<Shift-Button-1>",    self._on_canvas_shift)
        self._canvas.bind("<Control-Button-1>",  self._on_canvas_ctrl)

        for i in range(6):
            self.bind(str(i), lambda e,r=i: self._rate_selected_all(r))
        try: self.bind(get_hk(self._settings,"hk_tb_zin"),  lambda e: self._resize_thumbs(+20))
        except Exception: self.bind("<Control-equal>", lambda e: self._resize_thumbs(+20))
        try: self.bind(get_hk(self._settings,"hk_tb_zout"), lambda e: self._resize_thumbs(-20))
        except Exception: self.bind("<Control-minus>", lambda e: self._resize_thumbs(-20))

        for btn_num in (4,5,6,7,8,9):
            try: self._canvas.bind(f"<Button-{btn_num}>",
                                   lambda e,n=btn_num: self._tb_extra_btn(e,n))
            except Exception: pass

    def _toggle_bar_side(self):
        self._tb_bar_left = not self._tb_bar_left
        self._row_items.clear()
        self._rebuild_layout()
        self._full_refresh()


    def _tb_grab_start(self, e): self._tb_grab_y = e.y_root
    def _tb_grab_end(self, e):   self._tb_grab_y = None
    def _tb_grab_drag(self, e):
        if self._tb_grab_y is None: return
        dy = self._tb_grab_y - e.y_root; self._tb_grab_y = e.y_root
        new_h = max(30, min(200, self._tb_bar_h + dy))
        if new_h != self._tb_bar_h:
            self._tb_bar_h = new_h
            try: self._tbar_frame.config(height=new_h)
            except Exception: pass

    # ── Layout ────────────────────────────────────────────────────────────────

    def _build_rows_list(self):
        """Build self._rows_list: list of ('img', idx) or ('hdr', subdir_name)."""
        self._rows_list = []
        if self._tb_flat or not any(os.path.dirname(r) for r in self._images):
            for idx in range(len(self._images)):
                self._rows_list.append(("img", idx))
        else:
            # Group by subfolder in the order they appear in self._images
            # (preserves sort order within groups, shows headers at group boundaries)
            seen_dirs = {}   # dir -> header already emitted
            cur_dir   = None
            for idx, rel in enumerate(self._images):
                d = os.path.dirname(rel)
                if d != cur_dir:
                    cur_dir = d
                    if d not in seen_dirs:
                        seen_dirs[d] = True
                        self._rows_list.append(("hdr", d if d else "(root)"))
                self._rows_list.append(("img", idx))

    def _layout(self):
        cw = self._canvas.winfo_width() or 900
        T, B, P = self._thumb_size, TB_BORDER, TB_PAD
        self._cell_w = T + B*2 + P*2
        self._cell_h = T + TB_LABEL_H + B*2 + P*2

        self._cols = max(1, cw // self._cell_w)

        # Compute virtual row mapping: each entry in _rows_list may span 1 row
        # but images in a row-group fill cols positions.
        # We map linear rows to canvas y positions.
        self._row_y    = {}   # row_num -> y pixel start
        self._row_type = {}   # row_num -> ('img_row', first_idx) | ('hdr', name)

        self._row_indices = {}   # row_num -> [idx, idx, ...] for img_rows

        y = 0; row_num = 0; cur_row_idxs = []
        for entry in self._rows_list:
            if entry[0] == "hdr":
                if cur_row_idxs:  # close partial image row
                    self._row_indices[row_num] = cur_row_idxs
                    y += self._cell_h; row_num += 1; cur_row_idxs = []
                self._row_y[row_num]    = y
                self._row_type[row_num] = ("hdr", entry[1])
                y += self.HEADER_H; row_num += 1
            else:  # img entry
                if not cur_row_idxs:
                    self._row_y[row_num]    = y
                    self._row_type[row_num] = ("img_row", entry[1])  # first idx stored for compat
                cur_row_idxs.append(entry[1])
                if len(cur_row_idxs) >= self._cols:
                    self._row_indices[row_num] = cur_row_idxs
                    y += self._cell_h; row_num += 1; cur_row_idxs = []
        if cur_row_idxs:
            self._row_indices[row_num] = cur_row_idxs
            y += self._cell_h; row_num += 1

        self._total_h   = max(y, 1)
        self._num_rows  = row_num
        self._canvas.configure(scrollregion=(0, 0, cw, self._total_h))

    def _full_refresh(self, scroll_to=None):
        self._row_items.clear()
        self._canvas.delete("all")
        self._build_rows_list()
        self._layout()
        self._draw_visible()
        n = len(self._images)
        self.title(f"Thumbnail Browser – {n} images")
        if scroll_to:
            self._scroll_to_image(scroll_to)
        elif self._last_sel:
            self._scroll_to_image(self._last_sel)

    def _on_canvas_configure(self, e=None):
        if self._resize_job: self.after_cancel(self._resize_job)
        self._resize_job = self.after(80, self._full_refresh)

    # ── Virtual draw ──────────────────────────────────────────────────────────

    def _visible_rows(self):
        vh   = self._canvas.winfo_height() or 600
        yoff = int(self._canvas.yview()[0] * self._total_h)
        if not self._row_y: return 0, 0
        # Find first visible row_num
        r0 = max(0, self._y_to_row(yoff) - self.PREFETCH)
        r1 = min(self._num_rows - 1, self._y_to_row(yoff + vh) + self.PREFETCH)
        return r0, r1

    def _y_to_row(self, y):
        """Binary-search row_y for the row containing y."""
        lo, hi = 0, max(0, self._num_rows - 1)
        while lo < hi:
            mid = (lo + hi + 1) // 2
            if self._row_y.get(mid, self._total_h) <= y:
                lo = mid
            else:
                hi = mid - 1
        return lo

    def _draw_visible(self):
        if not self._images: return
        r0, r1 = self._visible_rows()
        keep_r0 = max(0, r0 - 2)
        keep_r1 = r1 + 2
        for row in list(self._row_items):
            if row < keep_r0 or row > keep_r1:
                for cid in self._row_items.pop(row):
                    self._canvas.delete(cid)
        for row in range(r0, r1+1):
            if row in self._row_items: continue
            rtype = self._row_type.get(row)
            if rtype is None: continue
            if rtype[0] == "hdr":
                self._draw_header_row(row, rtype[1])
            else:
                self._draw_image_row(row, rtype[1])
        self._request_visible_images(r0, r1)

    def _draw_header_row(self, row, name):
        cw  = self._canvas.winfo_width() or 900
        y0  = self._row_y[row]
        items = []
        items.append(self._canvas.create_rectangle(
            0, y0, cw, y0+self.HEADER_H, fill="#333344", outline=""))
        items.append(self._canvas.create_text(
            8, y0+self.HEADER_H//2, text=f"📁  {name}",
            fill=FG_RATING, font=("Segoe UI",9,"bold"), anchor=tk.W))
        self._row_items[row] = items

    def _draw_image_row(self, row, first_idx):
        """Draw a full image row; uses _row_indices[row] for the actual idx list."""
        T, B = self._thumb_size, TB_BORDER
        y0   = self._row_y[row]
        items = []

        row_idxs = self._row_indices.get(row, list(range(first_idx, min(first_idx+self._cols, len(self._images)))))
        for col_off, idx in enumerate(row_idxs):
            if idx >= len(self._images): break
            # Verify this idx belongs to this row
            # (Due to header rows breaking sequences, first_idx may not be contiguous)
            # We'll trust the caller is correct
            rel    = self._images[idx]
            rating = get_rating_from_name(rel)
            bc     = RATING_COLORS[rating] if rating is not None else UNRATED_COLOR
            lb_fg  = _text_fg_for_bg(bc)

            x0 = col_off * self._cell_w + TB_PAD
            xc = x0 + B
            yc = y0 + B
            sel = rel in self._selected
            border_col = self.SEL_COLOR if sel else bc

            r1 = self._canvas.create_rectangle(
                x0, y0, x0+self._thumb_size+B*2, y0+self._thumb_size+TB_LABEL_H+B*2,
                fill=border_col, outline="", tags=("cell", f"idx_{idx}"))
            r2 = self._canvas.create_rectangle(
                xc, yc, xc+self._thumb_size, yc+self._thumb_size+TB_LABEL_H,
                fill="#2a2a2a", outline="", tags=("cell", f"idx_{idx}"))
            r3 = self._canvas.create_text(
                xc+self._thumb_size//2, yc+self._thumb_size//2,
                text="…", fill=FG_DIM, font=("Segoe UI",14),
                tags=("cell", f"idx_{idx}", f"ph_{idx}"))
            ly = yc + self._thumb_size
            r4 = self._canvas.create_rectangle(
                xc, ly, xc+self._thumb_size, ly+TB_LABEL_H,
                fill=bc, outline="", tags=("cell", f"idx_{idx}"))
            bare  = strip_prefix(rel)
            short = bare if len(bare)<=22 else bare[:19]+"…"
            r5 = self._canvas.create_text(
                xc+2, ly+TB_LABEL_H//2, text=short,
                fill=lb_fg, font=("Segoe UI",7), anchor=tk.W,
                tags=("cell", f"idx_{idx}"))
            rstr = str(rating) if rating is not None else "·"
            r6 = self._canvas.create_text(
                xc+self._thumb_size-2, ly+TB_LABEL_H//2, text=rstr,
                fill=lb_fg, font=("Segoe UI",7,"bold"), anchor=tk.E,
                tags=("cell", f"idx_{idx}"))
            items.extend([r1,r2,r3,r4,r5,r6])

            key = (rel, self._thumb_size)
            if key in self._ph_cache:
                self._canvas.delete(r3); items.remove(r3)
                img_id = self._canvas.create_image(
                    xc, yc, anchor=tk.NW, image=self._ph_cache[key],
                    tags=("cell", f"idx_{idx}", f"img_{idx}"))
                items.append(img_id)

        self._row_items[row] = items

    def _redraw_cell(self, idx):
        # Find which row contains this idx
        row = self._idx_to_row(idx)
        if row is not None and row in self._row_items:
            for cid in self._row_items.pop(row): self._canvas.delete(cid)
            rtype = self._row_type.get(row)
            if rtype and rtype[0] == "img_row":
                self._draw_image_row(row, rtype[1])

    def _idx_to_row(self, idx):
        """Find the canvas row_num containing image index idx."""
        for row_num, idxs in self._row_indices.items():
            if idx in idxs:
                return row_num
        return None

    # ── Image loading ─────────────────────────────────────────────────────────

    def _request_visible_images(self, r0, r1):
        for row in range(r0, r1+1):
            rtype = self._row_type.get(row)
            if not rtype or rtype[0] != "img_row": continue
            for idx in self._row_indices.get(row, []):
                if idx >= len(self._images): break
                rel  = self._images[idx]
                key  = (rel, self._thumb_size)
                if key in self._ph_cache: continue
                if rel in self._loading: continue
                self._loading.add(rel)
                fpath = os.path.join(self.folder, rel)
                self._executor.submit(self._load_image_worker, rel, fpath, self._thumb_size)

    def _load_image_worker(self, rel, fpath, T):
        if self._closed: return
        try:
            pil = self._pil_cache.get(rel)
            if pil is None:
                pil = Image.open(fpath); pil.load()
                self._pil_cache[rel] = pil
            thumb = pil.copy(); thumb.thumbnail((T,T), Image.BILINEAR)
            self._result_q.put(("ok", rel, T, thumb))
        except Exception:
            self._result_q.put(("err", rel, T, None))

    def _drain_results(self):
        if self._closed: return
        for _ in range(40):
            try: status, rel, T, thumb = self._result_q.get_nowait()
            except Exception: break
            self._loading.discard(rel)
            key = (rel, T)
            if status == "ok" and T == self._thumb_size:
                ph = ImageTk.PhotoImage(thumb)
                self._ph_cache[key] = ph
                try:
                    idx = self._images.index(rel)
                    self._redraw_cell(idx)
                except ValueError: pass
        self.after(20, self._drain_results)

    # ── Scroll ────────────────────────────────────────────────────────────────

    def _on_vscroll(self, *args):
        self._canvas.yview(*args); self._draw_visible()

    def _on_scroll(self, event):
        if event.state & 0x4:
            self._resize_thumbs(20 if event.delta > 0 else -20)
        else:
            self._canvas.yview_scroll(-1*(event.delta//120), "units")
            self._draw_visible()

    def _resize_thumbs(self, delta):
        new = max(TB_SIZE_MIN, min(TB_SIZE_MAX, self._thumb_size + delta))
        if new == self._thumb_size: return
        self._thumb_size = new
        self._ph_cache.clear(); self._loading.clear()
        if self._resize_job: self.after_cancel(self._resize_job)
        self._resize_job = self.after(80, self._full_refresh)

    def _scroll_to_image(self, rel):
        """Scroll canvas so the cell for 'rel' is visible."""
        try:
            idx = self._images.index(rel)
        except ValueError: return
        row = self._idx_to_row(idx)
        if row is None: return
        y = self._row_y.get(row, 0)
        frac = y / max(1, self._total_h)
        self._canvas.yview_moveto(frac)
        self._draw_visible()

    def _scroll_to_subdir(self, subdir):
        """Scroll to the header row for subdir."""
        for row_num, rtype in self._row_type.items():
            if rtype[0] == "hdr" and (rtype[1] == subdir or rtype[1] == "(root)" and not subdir):
                y = self._row_y.get(row_num, 0)
                frac = y / max(1, self._total_h)
                self._canvas.yview_moveto(frac)
                self._draw_visible()
                return

    # ── Hit-testing ───────────────────────────────────────────────────────────

    def _canvas_xy_to_idx(self, cx, cy):
        cy_abs = cy + int(self._canvas.yview()[0] * self._total_h)
        row = self._y_to_row(cy_abs)
        rtype = self._row_type.get(row)
        if not rtype or rtype[0] != "img_row": return -1
        first = rtype[1]
        col   = cx // self._cell_w
        if col >= self._cols: return -1
        idx = first + col
        if idx >= len(self._images): return -1
        return idx

    def _on_canvas_click(self, e):
        idx = self._canvas_xy_to_idx(e.x, e.y)
        if idx < 0: return
        self._single_select(self._images[idx])

    def _on_canvas_dbl(self, e):
        idx = self._canvas_xy_to_idx(e.x, e.y)
        if idx < 0: return
        rel = self._images[idx]
        self._single_select(rel)
        if self._jump_cb:
            self._jump_cb(rel)
            # Bring main viewer to front
            try: self._parent.lift(); self._parent.focus_force()
            except Exception: pass

    def _on_canvas_shift(self, e):
        idx = self._canvas_xy_to_idx(e.x, e.y)
        if idx < 0: return
        fname = self._images[idx]
        if not self._last_sel or self._last_sel not in self._images:
            self._single_select(fname); return
        i1 = self._images.index(self._last_sel); i2 = idx
        lo, hi = min(i1,i2), max(i1,i2)
        old_sel = set(self._selected)
        self._selected = set(self._images[lo:hi+1])
        for rel in old_sel ^ self._selected:
            try: self._redraw_cell(self._images.index(rel))
            except ValueError: pass
        self._highlight_rating_button(get_rating_from_name(fname))
        self._update_tb_info(fname)

    def _on_canvas_ctrl(self, e):
        idx = self._canvas_xy_to_idx(e.x, e.y)
        if idx < 0: return
        rel = self._images[idx]
        if rel in self._selected: self._selected.discard(rel)
        else: self._selected.add(rel)
        self._last_sel = rel
        self._redraw_cell(idx)
        self._highlight_rating_button(get_rating_from_name(rel))
        self._update_tb_info(rel)

    def _single_select(self, rel):
        old_sel = set(self._selected)
        self._selected = {rel}; self._last_sel = rel
        for r in old_sel ^ self._selected:
            try: self._redraw_cell(self._images.index(r))
            except ValueError: pass
        self._highlight_rating_button(get_rating_from_name(rel))
        self._update_tb_info(rel)

    def _update_tb_info(self, rel):
        """Update the info panel with details about rel."""
        self._recolor_toolbar(rel)
        if not hasattr(self, "_tb_info_idx"): return
        rating = get_rating_from_name(rel)
        try: idx = self._images.index(rel)
        except ValueError: idx = -1
        dirpart = os.path.dirname(rel)

        self._tb_info_idx.config(text=f"{idx+1}/{len(self._images)}" if idx>=0 else "")
        self._tb_info_star.config(text=f"★ {rating}/5" if rating is not None else "★ –/5")
        # Update open comment dialog if any
        if hasattr(self, "_comment_dlg") and self._comment_dlg:
            try:
                if self._comment_dlg.winfo_exists():
                    self._comment_dlg.update_image(os.path.join(self.folder, rel))
            except Exception: self._comment_dlg = None

        if dirpart:
            sub_imgs = [i for i,r in enumerate(self._images) if os.path.dirname(r)==dirpart]
            sub_pos  = sub_imgs.index(idx)+1 if idx in sub_imgs else "?"
            self._tb_info_sub.config(text=f"{sub_pos}/{len(sub_imgs)}")
            short = dirpart if len(dirpart)<=12 else dirpart[:10]+"…"
            self._tb_info_subname.config(text=short)
        else:
            self._tb_info_sub.config(text="")
            self._tb_info_subname.config(text="")

        # Resolution: try PIL cache first, else skip
        pil = self._pil_cache.get(rel)
        if pil:
            self._tb_info_res.config(text=f"{pil.width}×{pil.height}")
        else:
            self._tb_info_res.config(text="")

    # ── Recolor toolbar on selection ──────────────────────────────────────────

    def _recolor_toolbar(self, rel):
        """Update all registered toolbar background frames to the rating color.
        Button boxes (#333xxx), info box (#222222), and the handle have fixed colors
        and are never in _tb_bg_frames, so they are never touched here."""
        rating    = get_rating_from_name(rel) if rel else None
        bar_color = rating_color(rating) if rating is not None else BG_PANEL
        dk        = _darken(bar_color, 0.7) if rating is not None else "#555555"
        for frame in getattr(self, "_tb_bg_frames", []):
            try: frame.config(bg=bar_color)
            except Exception: pass
        if hasattr(self, "_tb_container"):
            try: self._tb_container.config(bg=bar_color)
            except Exception: pass
        if self._tb_handle:
            try: self._tb_handle.config(bg=dk)
            except Exception: pass

    # ── Rating ────────────────────────────────────────────────────────────────

    def _highlight_rating_button(self, active_rating):
        for r, btn in self._rating_buttons.items():
            base = rating_color(r)
            if r == active_rating:
                btn.config(bg=base, fg=_rating_fg(r), highlightthickness=0)
            else:
                btn.config(bg=_darken(base,0.5), fg=_rating_fg(r), highlightthickness=0)

    def _rate_selected_all(self, rating):
        for rel in list(self._selected):
            self._rate_one(rel, rating)
        self._highlight_rating_button(rating)
        if self._last_sel:
            self._update_tb_info(self._last_sel)

    def _rate_one(self, old_rel, rating):
        dirpart  = os.path.dirname(old_rel)
        basename = os.path.basename(old_rel)
        new_base = rating_prefix(rating) + strip_prefix(basename)
        new_rel  = os.path.join(dirpart, new_base) if dirpart else new_base
        old_path = os.path.join(self.folder, old_rel)
        new_path = os.path.join(self.folder, new_rel)
        if new_rel != old_rel:
            try: os.rename(old_path, new_path)
            except Exception as ex:
                messagebox.showerror("Rename Error", str(ex)); return
            idx = self._images.index(old_rel)
            self._images[idx] = new_rel
            if old_rel in self._pil_cache:
                self._pil_cache[new_rel] = self._pil_cache.pop(old_rel)
            for T in list({k[1] for k in self._ph_cache}):
                if (old_rel,T) in self._ph_cache:
                    self._ph_cache[(new_rel,T)] = self._ph_cache.pop((old_rel,T))
            if old_rel in self._selected:
                self._selected.discard(old_rel); self._selected.add(new_rel)
            if self._last_sel == old_rel: self._last_sel = new_rel
            # Notify parent viewer so its image list stays in sync
            if self._rename_cb:
                try: self._rename_cb(old_rel, new_rel)
                except Exception: pass
        else:
            idx = self._images.index(old_rel)
        self._redraw_cell(idx)

    # ── Toolbar actions ───────────────────────────────────────────────────────

    def _open_folder(self):
        folder = filedialog.askdirectory(title="Select Folder", initialdir=self.folder)
        if not folder: return
        self.folder = folder
        files = []
        for root, dirs, fnames in os.walk(folder):
            dirs.sort()
            for f in sorted(fnames):
                if f.lower().endswith(".png"):
                    files.append(os.path.relpath(os.path.join(root,f), folder))
        self._all_images = sort_files(files, folder, self._sort_method)
        self._images     = list(self._all_images)
        self._pil_cache.clear(); self._ph_cache.clear()
        self._selected.clear(); self._last_sel = None; self._loading.clear()
        self._full_refresh()

    def _delete_trash(self):
        trash = [r for r in self._images if get_rating_from_name(os.path.basename(r)) == 0]
        if not trash:
            messagebox.showinfo("Delete Trash","No rating-0 files found.",parent=self); return
        if not messagebox.askyesno("Delete Trash",
                f"Permanently delete {len(trash)} file(s) rated 0?",parent=self): return
        for rel in trash:
            try:
                os.remove(os.path.join(self.folder, rel))
                self._images.remove(rel)
                self._pil_cache.pop(rel, None)
                for T in list({k[1] for k in self._ph_cache}):
                    self._ph_cache.pop((rel,T), None)
                self._selected.discard(rel)
            except Exception as ex:
                messagebox.showerror("Delete Error", str(ex), parent=self)
        self._full_refresh()

    def _open_sort_dialog(self):
        current = self._last_sel
        def _tb_reload():
            self._refresh()
            if self._images:
                first = self._images[0]
                self._single_select(first)
                self._scroll_to_image(first)
        SortDialog(self, self.folder, self._settings, reload_cb=_tb_reload)

    def _open_explorer_sel(self):
        if self._last_sel:
            open_in_explorer(os.path.join(self.folder, self._last_sel))
        else:
            open_in_explorer(self.folder)

    def _pick_sort(self): OrderDialog(self, self._sort_method, self._apply_sort, self._settings)

    def _apply_sort(self, method):
        self._sort_method = method
        self._images = sort_files(list(self._all_images), self.folder, method)
        self._full_refresh()
        self._settings["tb_sort"] = method; save_settings(self._settings)

    def _toggle_tb_flat(self):
        self._tb_flat = not self._tb_flat
        self._full_refresh()

    def _tb_subfolder_jump(self):
        def _tb_jump_idx(idx):
            if 0 <= idx < len(self._images):
                rel = self._images[idx]
                self._single_select(rel)
                self._scroll_to_image(rel)
        SubfolderDialog(self, self.folder, self._images, self._scroll_to_subdir,
                        self._settings, jump_to_idx_cb=_tb_jump_idx)

    def _show_comment(self):
        if not self._last_sel:
            messagebox.showinfo("No Selection","Select an image first.",parent=self); return
        fpath = os.path.join(self.folder, self._last_sel)
        if hasattr(self, "_comment_dlg") and self._comment_dlg and self._comment_dlg.winfo_exists():
            self._comment_dlg.update_image(fpath)
            self._comment_dlg.lift()
        else:
            self._comment_dlg = show_comment_dialog(
                self, fpath, self._settings,
                on_close=lambda: setattr(self, "_comment_dlg", None))

    def _rename_unrated_popup(self):
        dlg = tk.Toplevel(self)
        dlg.title("Unrated Prefix"); dlg.configure(bg=BG_DARK)
        dlg.resizable(False, False); dlg.transient(self); dlg.grab_set()
        tk.Label(dlg, text="Manage '-' prefix on unrated images:",
                 bg=BG_DARK, fg=FG_INFO, font=("Segoe UI",10)).pack(padx=20, pady=(16,8))
        def do_add():
            count = 0
            for i, rel in enumerate(self._images):
                base = os.path.basename(rel)
                if is_unrated(base):
                    dirpart = os.path.dirname(rel)
                    new_base = UNRATED_PREFIX + base
                    new_rel  = os.path.join(dirpart, new_base) if dirpart else new_base
                    try:
                        os.rename(os.path.join(self.folder,rel),
                                  os.path.join(self.folder,new_rel))
                        self._images[i] = new_rel; count += 1
                    except Exception: pass
            dlg.destroy(); self._full_refresh()
            messagebox.showinfo("Done", f"Added '-' prefix to {count} file(s).", parent=self)
        def do_remove():
            count = 0
            for i, rel in enumerate(self._images):
                base = os.path.basename(rel)
                if has_unrated_prefix(base):
                    dirpart  = os.path.dirname(rel)
                    new_base = strip_prefix(base)
                    new_rel  = os.path.join(dirpart, new_base) if dirpart else new_base
                    try:
                        os.rename(os.path.join(self.folder,rel),
                                  os.path.join(self.folder,new_rel))
                        self._images[i] = new_rel; count += 1
                    except Exception: pass
            dlg.destroy(); self._full_refresh()
            messagebox.showinfo("Done", f"Removed '-' prefix from {count} file(s).", parent=self)
        tk.Button(dlg, text="Add '-' to all truly unrated images",
                  command=do_add, bg="#336633", fg=FG_WHITE,
                  relief=tk.FLAT, font=("Segoe UI",10), pady=6, cursor="hand2").pack(
                  padx=20, pady=4, fill=tk.X)
        tk.Button(dlg, text="Remove '-' from all '-' prefixed images",
                  command=do_remove, bg="#334466", fg=FG_WHITE,
                  relief=tk.FLAT, font=("Segoe UI",10), pady=6, cursor="hand2").pack(
                  padx=20, pady=4, fill=tk.X)
        tk.Button(dlg, text="Cancel", command=dlg.destroy,
                  bg=BG_BTN, fg=FG_DIM, relief=tk.FLAT,
                  font=("Segoe UI",9), pady=4).pack(pady=(4,16))

    def _move_files(self):
        def done():
            self.after(100, self._open_folder)
        MoveFilesDialog(self, self.folder, self._settings, done)

    def _open_settings(self):
        SettingsDialog(self, self._settings)

    def _refresh(self):
        files = []
        for root, dirs, fnames in os.walk(self.folder):
            dirs.sort()
            for f in sorted(fnames):
                if f.lower().endswith(".png"):
                    files.append(os.path.relpath(os.path.join(root,f), self.folder))
        self._all_images = sort_files(files, self.folder, self._sort_method)
        self._images     = list(self._all_images)
        self._pil_cache.clear(); self._ph_cache.clear()
        self._selected.clear(); self._last_sel = None; self._loading.clear()
        self._full_refresh()




