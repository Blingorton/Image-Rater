        self._flat_btn_outer.pack(pady=2, padx=4, fill=tk.X)
        self._flat_btn = tk.Button(self._flat_btn_outer, text="⊟", command=self._toggle_flat,
                                    bg=BTN, fg=FG_WHITE, relief=tk.FLAT,
                                    font=("Segoe UI",9), pady=4, cursor="hand2")
        self._flat_btn.pack(fill=tk.X)
        tip(self._flat_btn, "Toggle flat mode (ignore subfolders in ordering)")
        self._update_flat_btn()
        sep()
        tb_btn("⚙S", self._open_settings, tooltip="Open settings")

        # Info box — one unified dark grey box; toolbar width controls the space,
        # no wraplength clipping. Labels use full available width.
        info_box = tk.Frame(tb, bg="#222222", padx=4, pady=6)
        info_box.pack(pady=(6,0), padx=2, fill=tk.X)
        def _ilabel(text="", fg=FG_RATING, font=("Segoe UI",9,"bold")):
            lbl = tk.Label(info_box, text=text, bg="#222222", fg=fg, font=font,
                           anchor=tk.CENTER, justify=tk.CENTER)
            lbl.pack(fill=tk.X, pady=1)
            return lbl
        self.index_label        = _ilabel(fg=FG_RATING, font=("Segoe UI",9,"bold"))
        self.subdir_index_label = _ilabel(fg=FG_RATING, font=("Segoe UI",7))
        self.subdir_name_label  = _ilabel(fg=FG_RATING, font=("Segoe UI",7))
        self.res_label          = _ilabel(fg="#aaaaaa",  font=("Segoe UI",7))
        self.star_label         = _ilabel(fg=FG_RATING, font=("Segoe UI",10,"bold"))

        self._lt_spacer = tk.Frame(tb, bg=BG_PANEL); self._lt_spacer.pack(fill=tk.Y, expand=True)

        bar_toggle_outer = tk.Frame(tb, bg="#333333", padx=3, pady=3)
        bar_toggle_outer.pack(pady=(0,6), padx=4, fill=tk.X)
        self._bar_toggle_btn = tk.Button(bar_toggle_outer, text="▬", command=self._cycle_rbar,
                                          bg="#484848", fg=FG_WHITE, relief=tk.FLAT,
                                          font=("Segoe UI",9), pady=4, cursor="hand2")
        self._bar_toggle_btn.pack(fill=tk.X)
        tip(self._bar_toggle_btn, "Cycle rating toolbar: bottom → hidden → sidebar")

    def _build_right_area(self):
        ra = self._right_area
        self._rbar_sidebar_frame = tk.Frame(ra, bg=BG_PANEL, width=54)
        self._img_area = tk.Frame(ra, bg=BG_DARK)
        self._img_area.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)

        self.canvas = tk.Canvas(self._img_area, bg=BG_DARK, highlightthickness=0)
        self.canvas.pack(fill=tk.BOTH, expand=True)
        self.canvas.bind("<Configure>", lambda e: self._redisplay())
        # canvas wheel handled at root level only

        self._rbar_outer = tk.Frame(self._img_area, bg=BG_PANEL)
        self._rbar_outer.pack(fill=tk.X, side=tk.BOTTOM)
        self._handle = tk.Frame(self._rbar_outer, bg="#555555", height=6,
                                 cursor="sb_v_double_arrow")
        self._handle.pack(fill=tk.X, side=tk.TOP)
        self._handle.bind("<ButtonPress-1>",   self._grab_start)
        self._handle.bind("<B1-Motion>",        self._grab_drag)
        self._handle.bind("<ButtonRelease-1>", self._grab_end)
        self._rbar = tk.Frame(self._rbar_outer, bg=BG_PANEL)
        self._rbar.pack(fill=tk.BOTH, expand=True)

        self._build_rating_bar()
        self._apply_rbar_state()

    def _build_rating_bar(self):
        for w in self._rbar.winfo_children(): w.destroy()
        self._rating_buttons.clear(); self._nav_buttons.clear()
        rating    = get_rating_from_name(self.images[self.index]) if self.images else None
        bar_color = rating_color(rating) if rating is not None else BG_PANEL
        self._rbar_outer.config(bg=bar_color)
        self._rbar.config(bg=bar_color)
        self._handle.config(bg=_darken(bar_color,0.7) if rating is not None else "#555555")
        h     = self._rbar_h
        btn_h = max(16, h-8)
        btn_w = max(22, int(btn_h*1.15))
        fs    = max(7, min(16, btn_h//3))
        row   = tk.Frame(self._rbar, bg=bar_color)
        row.pack(expand=True, anchor=tk.CENTER, pady=2)
        def make_btn(text, cmd, color, fg=FG_WHITE, tt=""):
            cell = tk.Frame(row, bg=bar_color, width=btn_w+6, height=btn_h+4)
            cell.pack_propagate(False); cell.pack(side=tk.LEFT, padx=2)
            b = tk.Button(cell, text=text, command=cmd, bg=color, fg=fg,
                          relief=tk.FLAT, font=("Segoe UI",fs,"bold"), cursor="hand2")
            b.place(relx=0.5, rely=0.5, anchor=tk.CENTER, width=btn_w, height=btn_h)
            if tt: tip(b, tt)
            return b
        self._nav_buttons['prev'] = make_btn("◀", self.prev_image, BG_BTN, tt="Previous image")
        cur_r = get_rating_from_name(self.images[self.index]) if self.images else 0
        max_r = max(5, (cur_r or 0) + 1)
        for i in range(max_r + 1):
            self._rating_buttons[i] = make_btn(str(i), lambda r=i: self.rate_image(r),
                                                rating_color(i), _rating_fg(i), tt=f"Rate as {i}")
        self._nav_buttons['next'] = make_btn("▶", self.next_image, BG_BTN, tt="Next image")
        if self.images:
            self._highlight_rating_button(get_rating_from_name(self.images[self.index]))

    def _build_rating_sidebar(self):
        sf = self._rbar_sidebar_frame
        for w in sf.winfo_children(): w.destroy()
        self._sidebar_btns.clear()
        rating    = get_rating_from_name(self.images[self.index]) if self.images else None
        bar_color = rating_color(rating) if rating is not None else BG_PANEL
        # Fix width to prevent resize on recolor
        sf.config(bg=bar_color, width=54)
        sf.pack_propagate(False)
        tk.Button(sf, text="▲", command=self.prev_image, bg=BG_BTN, fg=FG_WHITE,
                  relief=tk.FLAT, font=("Segoe UI",9,"bold"), cursor="hand2",
                  width=4, pady=4).pack(pady=(4,2), padx=2)
        cur_r2 = get_rating_from_name(self.images[self.index]) if self.images else 0
        max_r2 = max(5, (cur_r2 or 0) + 1)
        for i in list(range(max_r2, -1, -1)):
            b = tk.Button(sf, text=str(i), bg=rating_color(i), fg=_rating_fg(i),
                          relief=tk.FLAT, font=("Segoe UI",11,"bold"), cursor="hand2",
                          width=4, pady=6, command=lambda r=i: self.rate_image(r))
            b.pack(pady=2, padx=2)
            tip(b, f"Rate as {i}")
            self._sidebar_btns[i] = b
        tk.Button(sf, text="▼", command=self.next_image, bg=BG_BTN, fg=FG_WHITE,
                  relief=tk.FLAT, font=("Segoe UI",9,"bold"), cursor="hand2",
                  width=4, pady=4).pack(pady=(2,4), padx=2)
        if self.images:
            self._highlight_rating_button(rating)

    def _apply_rbar_state(self):
        state = self._rbar_state
        if state == self.RBAR_BOTTOM:
            self._rbar_outer.pack(fill=tk.X, side=tk.BOTTOM)
        else:
            self._rbar_outer.pack_forget()
        if state == self.RBAR_SIDEBAR:
            self._rbar_sidebar_frame.pack(side=tk.LEFT, fill=tk.Y, before=self._img_area)
            self._build_rating_sidebar()
        else:
            self._rbar_sidebar_frame.pack_forget()
        icons = ["▬","▬✗","◧"]
        self._bar_toggle_btn.config(text=icons[state])

    def _cycle_rbar(self):
        self._rbar_state = (self._rbar_state+1) % 3
        self._settings["rbar_state"] = self._rbar_state
        save_settings(self._settings)
        self._apply_rbar_state()

    # ── Grab handle ──────────────────────────────────────────────────────────

    def _grab_start(self, e): self._grab_y = e.y_root
    def _grab_end(self, e):   self._grab_y = None

    def _grab_drag(self, e):
        if self._grab_y is None: return
        dy = self._grab_y - e.y_root; self._grab_y = e.y_root
        new_h = max(RBAR_H_MIN, min(RBAR_H_MAX, self._rbar_h + dy))
        if new_h != self._rbar_h:
            self._rbar_h = new_h; self._build_rating_bar()

    # ── Toggles ──────────────────────────────────────────────────────────────

    def _toggle_auto_prefix(self):
        self._auto_prefix = not self._auto_prefix
        self._auto_btn.config(bg="#336633" if self._auto_prefix else "#663333",
                               text="A:-" if self._auto_prefix else "A:✗")

    def _toggle_flat(self):
        self._flat_mode = not self._flat_mode
        self._update_flat_btn()
        if self.folder:
            current_rel = self.images[self.index] if self.images else None
            self.load_folder(start_index=0)
            if current_rel and current_rel in self.images:
                self.index = self.images.index(current_rel)
                self.show_image()

    def _update_flat_btn(self):
        BTN = "#484848"
        self._flat_btn.config(bg="#336633" if self._flat_mode else BTN,
                               text="⊟" if self._flat_mode else "⊞✦")
        try:
            self._flat_btn_outer.config(bg="#224422" if self._flat_mode else "#333333")
        except Exception: pass

    # ── Key bindings ─────────────────────────────────────────────────────────

    def _bind_keys(self):
        s = self._settings
        def hk(key): return get_hk(s, key)

        # Navigation
        for seq in (hk("hk_prev"), hk("hk_prev2")):
            try: self.bind(seq, lambda e: self.prev_image())
            except Exception: pass
        for seq in (hk("hk_next"), hk("hk_next2")):
            try: self.bind(seq, lambda e: self.next_image())
            except Exception: pass
        # Rating
        for seq in (hk("hk_rate_0"), hk("hk_rate_0b")):
            try: self.bind(seq, lambda e: self.rate_image(0))
            except Exception: pass
        for r_key, r_num in (("hk_rate_1",1),("hk_rate_2",2),("hk_rate_3",3),
                              ("hk_rate_4",4),("hk_rate_5",5)):
            try: self.bind(hk(r_key), lambda e,r=r_num: self.rate_image(r))
            except Exception: pass
        # Zoom / fit
        for seq in (hk("hk_zoom_in"), "<plus>"):
            try: self.bind(seq, lambda e: self.zoom(1.2))
            except Exception: pass
        try: self.bind(hk("hk_zoom_out"), lambda e: self.zoom(1/1.2))
        except Exception: pass
        try: self.bind(hk("hk_fit"), lambda e: self.toggle_fit())
        except Exception: pass
        # Mouse extras (fixed)
        for btn_num in (4,5,6,7,8,9):
            try:
                self.bind(f"<Button-{btn_num}>",
                          lambda e,n=btn_num: self._any_extra_button(e,n))
            except Exception: pass
        for virt,cb in (("<XButton1>",self._mouse5),("<XButton2>",self._mouse4)):
            try: self.bind(virt, cb)
            except Exception: pass
        try:
            self.event_add("<<Mouse4>>","<Button-8>"); self.event_add("<<Mouse5>>","<Button-9>")
            self.bind("<<Mouse4>>",self._mouse5); self.bind("<<Mouse5>>",self._mouse4)
        except Exception: pass

    def _any_extra_button(self, e, num):
        if num in (4,8): self._mouse5(e)
        elif num in (5,9): self._mouse4(e)

    def _mouse4(self, e):
        if not self.images: return
        r = get_rating_from_name(self.images[self.index])
        self.rate_image(1 if r is None else r+1)

    def _mouse5(self, e):
        if not self.images: return
        r = get_rating_from_name(self.images[self.index])
        self.rate_image(0 if r is None else max(0,r-1))

    def _on_canvas_wheel(self, event):
        # Single event: no double-stepping. Delta >0 = scroll up = prev image.
        if event.delta > 0: self.prev_image()
        else: self.next_image()

    # ── Folder loading ────────────────────────────────────────────────────────

    def open_folder(self):
        def _default_dir():
            d = self._settings.get("default_folder", DEFAULT_FOLDER)
            if os.path.isdir(d): return d
            if os.path.isdir(DEFAULT_FOLDER): return DEFAULT_FOLDER
            return os.path.expanduser("~")
        start = self.folder or _default_dir()
        picker = FilePicker(self, start_dir=start, settings=self._settings)
        self.wait_window(picker)
        if not picker.result_folder: return
        self.folder = picker.result_folder
        sort_mode = getattr(picker, "result_sort", None)
        if sort_mode == "quick":
            # Run sort silently with saved rules, then load from index 0
            _run_sort_quick(self.folder, self._settings)
            self.load_folder(start_index=0)
        elif sort_mode == "custom":
            # Load folder first, then open sort dialog (which auto-closes after sort)
            self.load_folder(start_index=0)
            def _reload():
                self.load_folder(start_index=0)
            SortDialog(self, self.folder, self._settings, reload_cb=_reload)
        else:
            self.load_folder(start_index=0, target_file=getattr(picker, "result_file", None))

    def load_folder(self, start_index=0, target_file=None):
        files = []
        for root, dirs, fnames in os.walk(self.folder):
            dirs.sort()
            for f in sorted(fnames):
                if f.lower().endswith(".png"):
                    files.append(os.path.relpath(os.path.join(root,f), self.folder))
        if self._flat_mode:
            self.images = sort_files(files, self.folder, self._sort_method)
        else:
            groups = defaultdict(list)
            for rel in files: groups[os.path.dirname(rel)].append(rel)
            ordered = []
            for d in sorted(groups.keys()):
                ordered.extend(sort_files(groups[d], self.folder, self._sort_method))
            self.images = ordered
        if not self.images:
            messagebox.showinfo("No Images","No PNG files found."); return
        if target_file:
            # Find the index of the specifically chosen file
            for i, rel in enumerate(self.images):
                if os.path.basename(rel) == target_file:
                    start_index = i; break
        self.index = min(start_index, len(self.images)-1)
        self.show_image()

    # ── Thumbnail browser ─────────────────────────────────────────────────────

    def open_thumb_browser(self):
        # If no folder open, open folder picker first
        if not self.folder or not self.images:
            d = self._settings.get("default_folder", DEFAULT_FOLDER)
            start = d if os.path.isdir(d) else (DEFAULT_FOLDER if os.path.isdir(DEFAULT_FOLDER) else os.path.expanduser("~"))
            picker = FilePicker(self, start_dir=start, settings=self._settings)
            self.wait_window(picker)
            if not picker.result_folder: return
            self.folder = picker.result_folder
            self.load_folder(start_index=picker.result_index)
            if not self.images: return

        initial_sel = self.images[self.index] if self.images else None
        browser = ThumbnailBrowser(self, self.folder, list(self.images),
                                    self._settings,
                                    jump_cb=self._jump_to_image,
                                    rename_cb=self._on_tb_rename,
                                    initial_sel=initial_sel)
        browser.protocol("WM_DELETE_WINDOW", lambda: self._on_browser_close(browser))
        self._thumb_browser = browser

    def _on_tb_rename(self, old_rel, new_rel):
        """Keep ImageRater.images in sync when TB renames a file."""
        try:
            idx = self.images.index(old_rel)
            self.images[idx] = new_rel
            # If we're currently showing the renamed image, update index tracking
            if self.index == idx:
                pass  # index stays the same; show_image will use updated name
        except ValueError:
            pass

    def _jump_to_image(self, rel):
        # Exact match first
        if rel in self.images:
            self.index = self.images.index(rel)
        else:
            # Fall back to strip-prefix comparison (handles renamed files)
            rel_stripped = strip_prefix(os.path.basename(rel))
            for idx, r in enumerate(self.images):
                if strip_prefix(os.path.basename(r)) == rel_stripped:
                    self.index = idx; break
        self.show_image()
        self.lift(); self.focus_force()

    def _on_browser_close(self, browser):
        browser.destroy(); self._thumb_browser = None
        if self.folder: self.load_folder(start_index=self.index)

    # ── Navigation ────────────────────────────────────────────────────────────

    def next_image(self):
        if not self.images: return
        self.index = (self.index+1) % len(self.images); self.show_image()

    def prev_image(self):
        if not self.images: return
        self.index = (self.index-1) % len(self.images); self.show_image()

    def _open_subfolder_dialog(self):
        if not self.folder: messagebox.showinfo("No Folder","Open a folder first."); return
        def _ir_jump_idx(idx):
            self.index = idx; self.show_image()
        SubfolderDialog(self, self.folder, self.images, self._jump_to_subfolder,
                        self._settings, jump_to_idx_cb=_ir_jump_idx)

    def _jump_to_subfolder(self, subdir):
        for idx,rel in enumerate(self.images):
            if os.path.dirname(rel) == subdir:
                self.index = idx; self.show_image(); return

    # ── Display ──────────────────────────────────────────────────────────────

    def show_image(self):
        if not self.images: return
        rel      = self.images[self.index]
        basename = os.path.basename(rel)
        dirpart  = os.path.dirname(rel)
        if self._auto_prefix and is_unrated(basename):
            rel = self._apply_unrated_prefix(rel)
        path = os.path.join(self.folder, rel)
        try:
            self._orig_image = Image.open(path)
        except Exception as ex:
            messagebox.showerror("Error",f"Could not open image:\n{ex}"); return
        self._zoom = 1.0; self._fit = True
        self.fit_btn.config(relief=tk.SUNKEN)
        self._redisplay(); self._update_info()

    def _apply_unrated_prefix(self, rel):
        dirpart  = os.path.dirname(rel)
        basename = os.path.basename(rel)
        new_base = UNRATED_PREFIX + basename
        new_rel  = os.path.join(dirpart, new_base) if dirpart else new_base
        try:
            os.rename(os.path.join(self.folder,rel), os.path.join(self.folder,new_rel))
            self.images[self.index] = new_rel
            return new_rel
        except Exception as ex:
            messagebox.showerror("Rename Error",str(ex)); return rel

    def _update_info(self):
        rel      = self.images[self.index]
        dirpart  = os.path.dirname(rel)
        basename = os.path.basename(rel)
        w, h     = self._orig_image.size
        rating   = get_rating_from_name(basename)

        # Title: containing_folder / subfolder(if any) / filename
        folder_name = os.path.basename(self.folder) if self.folder else ""
        if dirpart:
            display = f"{folder_name}/{dirpart}/{basename}"
        else:
            display = f"{folder_name}/{basename}"
        self.title(display)
        self.index_label.config(text=f"{self.index+1}/{len(self.images)}")
        self.res_label.config(text=f"{w}×{h}")
        self.star_label.config(text=f"★ {rating}/5" if rating is not None else "·  ·")

        if dirpart and not self._flat_mode:
            sub_imgs = [i for i,r in enumerate(self.images) if os.path.dirname(r)==dirpart]
            sub_pos  = sub_imgs.index(self.index)+1 if self.index in sub_imgs else "?"
            self.subdir_index_label.config(text=f"{sub_pos}/{len(sub_imgs)}")
            short = dirpart if len(dirpart)<=10 else dirpart[:8]+"…"
            self.subdir_name_label.config(text=short)
        elif dirpart and self._flat_mode:
            short = dirpart if len(dirpart)<=10 else dirpart[:8]+"…"
            self.subdir_index_label.config(text="")
            self.subdir_name_label.config(text=f"[{short}]")
        else:
            self.subdir_index_label.config(text="")
            self.subdir_name_label.config(text="")

        self._highlight_rating_button(rating)
        self._apply_bar_color(rating)
        # Update open comment dialog if any
        if hasattr(self, "_comment_dlg") and self._comment_dlg:
            try:
                if self._comment_dlg.winfo_exists():
                    self._comment_dlg.update_image(os.path.join(self.folder, rel))
            except Exception: self._comment_dlg = None

    def _apply_bar_color(self, rating):
        """Recolor only the toolbar container frames to match current rating.
        Buttons keep their own colors; we only color the bare backgrounds."""
        bar_color = rating_color(rating) if rating is not None else BG_PANEL
        dk        = _darken(bar_color,0.7) if rating is not None else "#555555"

        # Left toolbar: frame itself + spacer (buttons are in fixed-color boxes)
        try: self._left_toolbar.config(bg=bar_color)
        except Exception: pass
        try: self._lt_spacer.config(bg=bar_color)
        except Exception: pass

        # Bottom rating bar
        if self._rbar_state == self.RBAR_BOTTOM:
            self._rbar_outer.config(bg=bar_color)
            self._rbar.config(bg=bar_color)
            self._handle.config(bg=dk)
            for row_frame in self._rbar.winfo_children():
                try: row_frame.config(bg=bar_color)
                except Exception: pass
                for cell in row_frame.winfo_children():
                    try: cell.config(bg=bar_color)
                    except Exception: pass
        # Sidebar
        elif self._rbar_state == self.RBAR_SIDEBAR:
            # Only recolor bg, don't touch size
            self._rbar_sidebar_frame.config(bg=bar_color)

    def _open_settings(self):
        SettingsDialog(self, self._settings)

    def _update_title(self):
        self.title("Image Rater")

    def _highlight_rating_button(self, active_rating):
        for r,btn in self._rating_buttons.items():
            base = RATING_COLORS[r]
            if r == active_rating:
                btn.config(bg=base, fg=_rating_fg(r), highlightthickness=3,
                           highlightbackground="#ffffff", highlightcolor="#ffffff")
            else:
                btn.config(bg=_darken(base,0.5), fg=_rating_fg(r), highlightthickness=0)
        for r,btn in self._sidebar_btns.items():
            base = RATING_COLORS[r]
            if r == active_rating:
                btn.config(bg=base, fg=_rating_fg(r), highlightthickness=3,
                           highlightbackground="#ffffff", highlightcolor="#ffffff")
            else:
                btn.config(bg=_darken(base,0.5), fg=_rating_fg(r), highlightthickness=0)

    def _redisplay(self):
        if not hasattr(self,"_orig_image") or self._orig_image is None: return
        cw = self.canvas.winfo_width(); ch = self.canvas.winfo_height()
        if cw < 2 or ch < 2: return
        img    = self._orig_image.copy()
        iw, ih = img.size
        scale  = min(cw/iw, ch/ih, 1.0) if self._fit else self._zoom
        nw, nh = max(1,int(iw*scale)), max(1,int(ih*scale))
        img    = img.resize((nw,nh), Image.LANCZOS)
        self._photo = ImageTk.PhotoImage(img)
        self.canvas.delete("all")
        self.canvas.create_image(cw//2, ch//2, anchor=tk.CENTER, image=self._photo)

    def zoom(self, factor):
        self._fit = False; self.fit_btn.config(relief=tk.FLAT)
        self._zoom *= factor; self._redisplay()

    def toggle_fit(self):
        self._fit = not self._fit
        self.fit_btn.config(relief=tk.SUNKEN if self._fit else tk.FLAT)
        if self._fit: self._zoom = 1.0
        self._redisplay()

    # ── Rating ────────────────────────────────────────────────────────────────

    def rate_image(self, rating):
        if not self.images: return
        rel      = self.images[self.index]
        dirpart  = os.path.dirname(rel)
        basename = os.path.basename(rel)
        new_base = rating_prefix(rating) + strip_prefix(basename)
        new_rel  = os.path.join(dirpart, new_base) if dirpart else new_base
        if new_rel != rel:
            try:
                os.rename(os.path.join(self.folder,rel), os.path.join(self.folder,new_rel))
            except Exception as ex:
                messagebox.showerror("Rename Error",str(ex)); return
            self.images[self.index] = new_rel
        self._update_info()
        if self._rbar_state == self.RBAR_BOTTOM:
            self._build_rating_bar()
        elif self._rbar_state == self.RBAR_SIDEBAR:
            self._build_rating_sidebar()

    # ── Utilities ─────────────────────────────────────────────────────────────

    def _delete_trash(self):
        if not self.folder: return
        trash = []
        for rel in self.images:
            if get_rating_from_name(os.path.basename(rel)) == 0:
                trash.append(rel)
        if not trash:
            messagebox.showinfo("Delete Trash","No rating-0 files found."); return
        if not messagebox.askyesno("Delete Trash",
                f"Permanently delete {len(trash)} file(s) rated 0?",parent=self): return
        for rel in trash:
            try: os.remove(os.path.join(self.folder,rel))
            except Exception: pass
        self.load_folder(start_index=min(self.index, max(0,len(self.images)-len(trash)-1)))

    def _open_sort_dialog(self):
        if not self.folder: messagebox.showinfo("No Folder","Open a folder first."); return
        current = self.images[self.index] if self.images else None
        def _reload():
            self.load_folder(start_index=0)
        SortDialog(self, self.folder, self._settings, reload_cb=_reload)

    def _open_explorer(self):
        if not self.folder: return
        rel = self.images[self.index] if self.images else ""
        open_in_explorer(os.path.join(self.folder,rel) if rel else self.folder)

    def _show_comment(self):
        if not self.images: messagebox.showinfo("No Image","No image loaded."); return
        rel   = self.images[self.index]
        fpath = os.path.join(self.folder, rel)
        if hasattr(self, "_comment_dlg") and self._comment_dlg and self._comment_dlg.winfo_exists():
            self._comment_dlg.update_image(fpath)
            self._comment_dlg.lift()
        else:
            self._comment_dlg = show_comment_dialog(
                self, fpath, self._settings,
                on_close=lambda: setattr(self, "_comment_dlg", None))

    def _move_files(self):
        if not self.folder: messagebox.showinfo("No Folder","Open a folder first."); return
        def done():
            self.folder = None; self.images = []
            self._update_title()
            self.after(100, self.open_folder)
        MoveFilesDialog(self, self.folder, self._settings, done)

    def _pick_sort(self): OrderDialog(self, self._sort_method, self._apply_sort, self._settings)

    def _apply_sort(self, method):
        self._sort_method = method
        self._settings["sort_method"] = method; save_settings(self._settings)
        if self.folder: self.load_folder(start_index=self.index)

    def _rate_unrated_as_trash(self):
        if not self.folder: return
        count = 0
        for i,rel in enumerate(self.images):
            basename = os.path.basename(rel)
            if has_unrated_prefix(basename):
                dirpart  = os.path.dirname(rel)
                new_base = RATING_PREFIXES[0] + strip_prefix(basename)
                new_rel  = os.path.join(dirpart,new_base) if dirpart else new_base
                try:
                    os.rename(os.path.join(self.folder,rel),
                              os.path.join(self.folder,new_rel))
                    self.images[i] = new_rel; count += 1
                except Exception: pass
        if count:
            messagebox.showinfo("Done",f"Rated {count} '-' file(s) as 0.")
            self._update_info()

