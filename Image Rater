                      font=("Segoe UI",8), pady=3, padx=8, cursor="hand2"),
                "Jump to end of contiguous prefixed run across all images"
                ).pack(side=tk.LEFT, padx=(0,4))
            tip(tk.Button(gf, text="⭐ Last rated (all)",
                      command=lambda: _btn_last_rated(all_pairs),
                      bg="#334433", fg=FG_WHITE, relief=tk.FLAT,
                      font=("Segoe UI",8), pady=3, padx=8, cursor="hand2"),
                "Jump to first rated image across all images"
                ).pack(side=tk.LEFT)

        # ── scrollable subfolder list ─────────────────────────────────────────
        list_frame = tk.Frame(self, bg=BG_DARK)
        list_frame.pack(fill=tk.BOTH, expand=True, padx=6, pady=(0,4))
        vsb = tk.Scrollbar(list_frame, bg=BG_PANEL, troughcolor=BG_DARK)
        vsb.pack(side=tk.RIGHT, fill=tk.Y)
        canvas = tk.Canvas(list_frame, bg=BG_DARK, highlightthickness=0,
                           yscrollcommand=vsb.set)
        canvas.pack(fill=tk.BOTH, expand=True)
        vsb.config(command=canvas.yview)
        inner = tk.Frame(canvas, bg=BG_DARK)
        canvas.create_window((0, 0), window=inner, anchor=tk.NW)
        inner.bind("<Configure>",
                   lambda e: canvas.configure(scrollregion=canvas.bbox("all")))
        canvas.bind("<MouseWheel>",
                    lambda e: canvas.yview_scroll(-1*(e.delta//120), "units"))

        for row_i, subdir in enumerate(subdirs):
            if not subdir: continue   # skip root-level (no subdir name)
            row_bg = BG_DARK if row_i % 2 == 0 else "#252525"
            row = tk.Frame(inner, bg=row_bg); row.pack(fill=tk.X, pady=1)

            # Subfolder name — click to jump to first image
            name_btn = tk.Button(row, text=f"  📁 {subdir}",
                                  command=lambda d=subdir: (jump_cb(d), self.destroy()),
                                  bg=row_bg, fg=FG_INFO, relief=tk.FLAT,
