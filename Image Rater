        self._canvas.bind("<Configure>", lambda _: self._reflow())
        self._canvas.bind("<MouseWheel>",
                          lambda e: self._canvas.yview_scroll(-1*(e.delta//120),"units"))
        self._grid = tk.Frame(self._canvas, bg=BG_DARK)
        self._cw   = self._canvas.create_window((0,0), window=self._grid, anchor=tk.NW)
        self._grid.bind("<Configure>",
                        lambda _: self._canvas.configure(scrollregion=self._canvas.bbox("all")))

        bot = tk.Frame(self, bg=BG_PANEL, pady=6); bot.pack(fill=tk.X, side=tk.BOTTOM)
        self._status = tk.Label(bot, text="", bg=BG_PANEL, fg=FG_DIM, font=("Segoe UI",8))
        self._status.pack(side=tk.LEFT, padx=10)
        tip(tk.Button(bot, text="Cancel", command=self.destroy, bg=BG_BTN, fg=FG_WHITE,
                  relief=tk.FLAT, padx=12, pady=4, font=("Segoe UI",9),
                  cursor="hand2"), "Cancel").pack(side=tk.RIGHT, padx=6)
        tip(tk.Button(bot, text="Move Files Here", command=self._do_move,
                  bg="#406080", fg=FG_WHITE, relief=tk.FLAT, padx=12, pady=4,
