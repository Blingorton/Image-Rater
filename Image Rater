    def _hk_start_listen(self, key):
        """Enter listening mode for the given action key."""
        # Cancel any previous listen
        if self._hk_listen and self._hk_listen in self._hk_btn:
            old = self._hk_listen
            self._hk_btn[old].config(bg="#2a3a4a", fg="#88bbff",
                                      text=hk_display(self._hk_vars[old].get()))
        self._hk_listen = key
        self._hk_btn[key].config(bg="#553300", fg="#ffcc44", text="Press key…")
        self.focus_set()

    def _hk_capture(self, event):
        """Capture a keypress and assign it to the listening action."""
        if not self._hk_listen: return
        # Ignore pure modifier presses
        if event.keysym in ("Control_L","Control_R","Alt_L","Alt_R",
                             "Shift_L","Shift_R","Super_L","Super_R",
                             "Caps_Lock","Num_Lock","Scroll_Lock"): return
        # Build tk sequence
        mods = ""
        if event.state & 0x4:  mods += "Control-"
        if event.state & 0x8:  mods += "Alt-"
        if event.state & 0x1:  mods += "Shift-"
        sym = event.keysym
        # For plain printable single chars, store without angle brackets
        if len(sym) == 1 and not mods:
            seq = sym
        else:
            seq = f"<{mods}{sym}>"
        key = self._hk_listen
        self._hk_vars[key].set(seq)
        self._hk_btn[key].config(bg="#2a3a4a", fg="#88bbff", text=hk_display(seq))
        self._hk_listen = None

    def _hk_reset(self, key, default):
        """Reset a hotkey to its default."""
        self._hk_vars[key].set(default)
        if key in self._hk_btn:
            self._hk_btn[key].config(bg="#2a3a4a", fg="#88bbff",
                                      text=hk_display(default))
        if self._hk_listen == key:
            self._hk_listen = None

