DEFAULT_FOLDER  = r"I:\SD outputs"
SETTINGS_FILE   = os.path.join(os.path.dirname(os.path.abspath(__file__)),
                                "image_rater_settings.json")

RATING_PREFIXES = {5:"____", 4:"___", 3:"__", 2:"_", 1:"=", 0:"zzz_trash_"}
UNRATED_PREFIX  = "-"
ALL_PREFIXES    = sorted(list(RATING_PREFIXES.values()) + [UNRATED_PREFIX],
                         key=len, reverse=True)

RATING_COLORS   = {0:"#cc2222", 1:"#dddddd", 2:"#33aa44",
                   3:"#3366cc", 4:"#883fcc", 5:"#dd7722"}

def rating_prefix(r):
    """Return file prefix for rating r (handles r > 5).
    n underscores = rating n+1, so rating r uses r-1 underscores.
    """
    if r in RATING_PREFIXES: return RATING_PREFIXES[r]
    if r > 5: return "_" * (r - 1)  # rating 6 → 5 underscores, etc.
    return ""

def rating_color(r):
    """Return display color for rating r (clamps to 0-5 palette)."""
    return RATING_COLORS[max(0, min(5, r))]
