                  command=self._do_rate_trash_move,
                  bg="#662222", fg=FG_WHITE, relief=tk.FLAT, padx=12, pady=4,
                  font=("Segoe UI",9,"bold"), cursor="hand2"),
            "Rate all '-' prefixed files as 0, delete all rating-0 files, then move the rest here"
            ).pack(side=tk.RIGHT, padx=4)

    def _navigate(self, path):
        path = os.path.normpath(path)
        if not os.path.isdir(path): return
        self._load_queue.clear()
        self.current_dir = path; self._path_var.set(path)
        for w in self._grid.winfo_children(): w.destroy()
        self._thumbs.clear()
        try: entries = sorted(os.listdir(path))
        except PermissionError: return
        subdirs = [e for e in entries if os.path.isdir(os.path.join(path,e))]
        self._status.config(text=f"{len(subdirs)} subfolders")
        T, P = self.THUMB, self.PAD
        cell_w, cell_h = T+P*2, T+P*2+18
        for dname in subdirs:
            cell = tk.Frame(self._grid, bg="#383838", width=cell_w, height=cell_h, cursor="hand2")
            cell.pack_propagate(False)
            icon = tk.Label(cell, text="📁", bg="#383838", fg="#f0c040", font=("Segoe UI",28))
            icon.place(x=0, y=P, width=cell_w, height=T)
            short = dname if len(dname)<=13 else dname[:10]+"…"
            tk.Label(cell, text=short, bg="#383838", fg=FG_INFO, font=("Segoe UI",7),
                     wraplength=cell_w-4).place(x=2, y=T+P, width=cell_w-4)
            for w in (cell, icon):
                w.bind("<Button-1>", lambda e,d=dname: self._navigate(os.path.join(self.current_dir,d)))
        self.after(60, self._reflow)

    def _reflow(self):
        cw = self._canvas.winfo_width() or 860
        cell_w = self.THUMB + self.PAD*2 + 4
        cols   = max(1, cw // cell_w)
        for idx,child in enumerate(self._grid.winfo_children()):
            r,c = divmod(idx, cols)
            child.grid(row=r, column=c, padx=self.PAD, pady=self.PAD)
        self._canvas.itemconfig(self._cw, width=cw)
        self._canvas.configure(scrollregion=self._canvas.bbox("all"))

    def _go_up(self):
        p = os.path.dirname(self.current_dir)
        if p != self.current_dir: self._navigate(p)

    def _do_rate_trash_move(self):
        dest = self.current_dir
        # Count what will happen so the confirmation is informative
        to_trash = []   # files with '-' prefix → will be rated 0 then deleted
        already_trash = []  # files already rated 0 → will be deleted
        for root, dirs, fnames in os.walk(self._source):
            dirs.sort()
            for f in fnames:
                base = os.path.basename(f)
                if has_unrated_prefix(base):
                    to_trash.append(os.path.join(root, f))
                elif get_rating_from_name(base) == 0:
                    already_trash.append(os.path.join(root, f))
        total_delete = len(to_trash) + len(already_trash)
        if not messagebox.askyesno(
                "Rate → Delete → Move",
                f"This will perform 3 steps on:\n  {self._source}\n\n"
                f"  1. Rate all {len(to_trash)} '-' prefixed file(s) as 0 (trash)\n"
                f"  2. Delete all {total_delete} rating-0 file(s)\n"
                f"  3. Move remaining files into:\n     {dest}\n\n"
                f"Deleted files cannot be recovered. Continue?",
                parent=self): return
        self._settings["move_dest_folder"] = dest
        save_settings(self._settings)
        # Step 1: rename '-' prefixed files to 'zzz_trash_' prefix
        renamed = rename_err = 0
        for fpath in to_trash:
            dirpart  = os.path.dirname(fpath)
            base     = os.path.basename(fpath)
            new_base = rating_prefix(0) + strip_prefix(base)
            new_path = os.path.join(dirpart, new_base)
            try: os.rename(fpath, new_path); renamed += 1
            except Exception: rename_err += 1
        # Step 2: delete all rating-0 files (re-walk to catch newly renamed ones)
        deleted = del_err = 0
        for root, dirs, fnames in os.walk(self._source):
            dirs.sort()
            for f in fnames:
                if get_rating_from_name(f) == 0:
                    try: os.remove(os.path.join(root, f)); deleted += 1
                    except Exception: del_err += 1
        # Step 3: move remaining files
        moved = move_err = 0
        for root, dirs, fnames in os.walk(self._source):
            dirs.sort()
            for f in fnames:
                src_path = os.path.join(root, f)
                rel      = os.path.relpath(src_path, self._source)
                dst_path = os.path.join(dest, rel)
                os.makedirs(os.path.dirname(dst_path), exist_ok=True)
                try: shutil.move(src_path, dst_path); moved += 1
                except Exception: move_err += 1
        # Delete source folder if now empty
        msg = (f"Step 1: rated {renamed} file(s) as trash"
               + (f" ({rename_err} error(s))" if rename_err else "") + "\n"
               + f"Step 2: deleted {deleted} file(s)"
               + (f" ({del_err} error(s))" if del_err else "") + "\n"
               + f"Step 3: moved {moved} file(s)"
               + (f" ({move_err} error(s))" if move_err else ""))
        total_errors = rename_err + del_err + move_err
        if not total_errors:
            all_empty = all(not fnames
                            for _, _, fnames in os.walk(self._source))
            if all_empty:
                try:
                    shutil.rmtree(self._source)
                    msg += "\nSource folder deleted (was empty)."
                except Exception as ex:
                    msg += f"\nCould not delete source folder: {ex}"
        messagebox.showinfo("Complete", msg, parent=self)
        self._done_cb()
        self.destroy()

    def _do_move(self):
        dest = self.current_dir
        if not messagebox.askyesno("Move Files",
                f"Move all files from:\n  {self._source}\ninto:\n  {dest}\n\nSubfolder structure will be preserved.",
                parent=self): return
        self._settings["move_dest_folder"] = dest
        save_settings(self._settings)
        moved = errors = 0
        for root, dirs, fnames in os.walk(self._source):
            dirs.sort()
            for f in fnames:
                src_path = os.path.join(root, f)
                rel      = os.path.relpath(src_path, self._source)
                dst_path = os.path.join(dest, rel)
                os.makedirs(os.path.dirname(dst_path), exist_ok=True)
                try: shutil.move(src_path, dst_path); moved += 1
                except Exception: errors += 1
        msg = f"Moved {moved} file(s)."
        if errors: msg += f" {errors} error(s)."
        # Delete source folder if it is now entirely empty (no files remain)
        deleted_src = False
        if not errors:
            all_empty = True
            for root, dirs, fnames in os.walk(self._source):
                if fnames:
                    all_empty = False; break
            if all_empty:
                try:
                    shutil.rmtree(self._source)
                    deleted_src = True
                    msg += f"\nSource folder deleted (was empty)."
                except Exception as ex:
                    msg += f"\nCould not delete source folder: {ex}"
        messagebox.showinfo("Move Complete", msg, parent=self)
        self._done_cb()
        self.destroy()

