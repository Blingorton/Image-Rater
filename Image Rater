class SortDialog(tk.Toplevel):
    ROWS = 20
    def __init__(self, parent, folder, settings, reload_cb=None):
        super().__init__(parent)
        self.title("Sort by Comment Keywords")
        self.configure(bg=BG_DARK)
        self.resizable(True, True)
        self.transient(parent)
        self.grab_set()
        self._folder = folder; self._settings = settings; self._rows = []
        self._reload_cb = reload_cb
        self._build_ui(); self._load_saved()
        restore_popup_geom(self, settings, "sort_kw", "700x560")
        bind_popup_geom(self, settings, "sort_kw")
        self.protocol("WM_DELETE_WINDOW", self._close)

    def _build_ui(self):
        hdr = tk.Frame(self, bg=BG_PANEL, pady=6); hdr.pack(fill=tk.X)
        tk.Label(hdr, text="Search comment for:", bg=BG_PANEL, fg=FG_INFO,
                 font=("Segoe UI",9,"bold"), width=28, anchor=tk.W).pack(side=tk.LEFT, padx=(12,0))
        tk.Label(hdr, text="Move to subfolder (blank = use keyword):", bg=BG_PANEL, fg=FG_INFO,
                 font=("Segoe UI",9,"bold")).pack(side=tk.LEFT, padx=12)
        body = tk.Frame(self, bg=BG_DARK); body.pack(fill=tk.BOTH, expand=True, padx=8, pady=4)
        for i in range(self.ROWS):
            row = tk.Frame(body, bg=BG_DARK); row.pack(fill=tk.X, pady=1)
            kv, fv = tk.StringVar(), tk.StringVar()
            tk.Label(row, text=f"{i+1:2}.", bg=BG_DARK, fg=FG_DIM,
                     font=("Segoe UI",8), width=3).pack(side=tk.LEFT)
            tk.Entry(row, textvariable=kv, bg="#333", fg=FG_WHITE,
                     insertbackground=FG_WHITE, relief=tk.FLAT,
                     font=("Segoe UI",9), width=28).pack(side=tk.LEFT, padx=(2,6))
            tk.Entry(row, textvariable=fv, bg="#333", fg=FG_WHITE,
                     insertbackground=FG_WHITE, relief=tk.FLAT,
                     font=("Segoe UI",9), width=28).pack(side=tk.LEFT)
            self._rows.append((kv, fv))
        bot = tk.Frame(self, bg=BG_PANEL, pady=8); bot.pack(fill=tk.X, side=tk.BOTTOM)
        tk.Button(bot, text="Sort", command=self._do_sort, bg="#336633", fg=FG_WHITE,
                  relief=tk.FLAT, font=("Segoe UI",10,"bold"), padx=20, pady=6,
                  cursor="hand2").pack(side=tk.RIGHT, padx=10)
        tk.Button(bot, text="Close", command=self._close, bg=BG_BTN, fg=FG_WHITE,
                  relief=tk.FLAT, font=("Segoe UI",9), padx=12, pady=6,
                  cursor="hand2").pack(side=tk.RIGHT, padx=4)
        self._status = tk.Label(bot, text="", bg=BG_PANEL, fg=FG_RATING, font=("Segoe UI",8))
        self._status.pack(side=tk.LEFT, padx=10)

    def _load_saved(self):
        saved = self._settings.get("sort_rows", [])
        for i,(kv,fv) in enumerate(self._rows):
            if i < len(saved): kv.set(saved[i][0]); fv.set(saved[i][1])

    def _save_rows(self):
        self._settings["sort_rows"] = [[k.get(),f.get()] for k,f in self._rows]
        save_settings(self._settings)

    def _do_sort(self):
        if not self._folder: self._status.config(text="No folder loaded."); return
        rules = [(k.get().strip(), f.get().strip() or k.get().strip())
                 for k,f in self._rows if k.get().strip()]
        if not rules: self._status.config(text="No rules entered."); return
        self._save_rows()
        moved = errors = 0
        for fname in [f for f in os.listdir(self._folder) if f.lower().endswith(".png")]:
            fpath = os.path.join(self._folder, fname)
            comment = get_png_comment(fpath)
            for kw, fld in rules:
                if kw.lower() in comment.lower():
                    dest = os.path.join(self._folder, fld)
                    os.makedirs(dest, exist_ok=True)
                    try: shutil.move(fpath, os.path.join(dest, fname)); moved += 1
                    except Exception: errors += 1
                    break
        msg = f"Moved {moved} file(s)."
        if errors: msg += f" {errors} error(s)."
        self._status.config(text=msg)
        if moved and self._reload_cb:
            try: self._reload_cb()
            except Exception: pass
            self.after(200, self.destroy)   # brief pause so status is visible, then close

    def _close(self): self._save_rows(); self.destroy()

