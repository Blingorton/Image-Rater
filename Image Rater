def get_hk(settings, key):
    """Return the effective tk sequence for an action."""
    default = HOTKEY_DEFAULTS[key][1]
    return settings.get(key, default)

def hk_display(seq):
    """Convert a tk sequence like <Control-equal> to a readable string."""
    s = seq.strip("<>")
    s = s.replace("Control-", "Ctrl+")
    s = s.replace("Alt-", "Alt+")
    s = s.replace("Shift-", "Shift+")
    # Special key names
    names = {"grave": "`", "equal": "=", "minus": "-", "plus": "+",
             "space": "Space", "Return": "Enter", "BackSpace": "Backspace",
             "Delete": "Del", "Escape": "Esc", "Tab": "Tab",
             "Left": "←", "Right": "→", "Up": "↑", "Down": "↓",
             "F1":"F1","F2":"F2","F3":"F3","F4":"F4","F5":"F5",
             "F6":"F6","F7":"F7","F8":"F8","F9":"F9","F10":"F10",
             "F11":"F11","F12":"F12"}
    # Handle modifier+key
    parts = s.split("+")
    parts[-1] = names.get(parts[-1], parts[-1])
    return "+".join(parts)

# ── Settings ─────────────────────────────────────────────────────────────────

def load_settings():
    try:
        with open(SETTINGS_FILE) as f:
            return json.load(f)
    except Exception:
        return {}

def save_settings(data):
    try:
        with open(SETTINGS_FILE, "w") as f:
            json.dump(data, f, indent=2)
    except Exception:
        pass


def _popup_geom_key(name): return f"popup_geom_{name}"

def restore_popup_geom(window, settings, name, default=None):
    """Restore saved geometry for a named popup window."""
    key  = _popup_geom_key(name)
    geom = settings.get(key)
    if geom:
        try: window.geometry(geom); return
        except Exception: pass
    if default:
        try: window.geometry(default)
        except Exception: pass

def bind_popup_geom(window, settings, name):
    """Bind geometry saving for a named popup window."""
    _job = [None]
    def _save(e=None):
        if _job[0]: window.after_cancel(_job[0])
        _job[0] = window.after(400, _do_save)
    def _do_save():
        try:
            settings[_popup_geom_key(name)] = window.geometry()
            save_settings(settings)
        except Exception: pass
    window.bind("<Configure>", _save)

# ── Helpers ──────────────────────────────────────────────────────────────────

def strip_prefix(name):
    base = os.path.basename(name)
    # Handle extended underscore prefixes (rating > 5) first
    n = 0
    for ch in base:
        if ch == "_": n += 1
        else: break
    if n >= 2:
        return base[n:]
    # Fixed prefixes
    for p in ALL_PREFIXES:
        if base.startswith(p):
            return base[len(p):]
    return base

def get_rating_from_name(name):
    base = os.path.basename(name)
    # Check non-underscore fixed prefixes first (0=zzz_trash_, 1==)
    for r in (0, 1):
        if base.startswith(RATING_PREFIXES[r]):
            return r
    # Count leading underscores — n underscores = rating n+1
    # (1 underscore = rating 2, 2 = rating 3, ..., 4 = rating 5, 5 = rating 6, ...)
    n = 0
    for ch in base:
        if ch == "_": n += 1
        else: break
    if n >= 1:
        return n + 1
    return None

def is_unrated(name):
    base = os.path.basename(name)
    # Has any rating (including >5 underscores)?
    if get_rating_from_name(base) is not None: return False
    if base.startswith(UNRATED_PREFIX): return False
    return True

def has_unrated_prefix(name):
    return (os.path.basename(name).startswith(UNRATED_PREFIX)
            and get_rating_from_name(name) is None)

def sort_key_strip(name):
    return strip_prefix(name).lower()

def _darken(c, f):
    h = c.lstrip("#")
    r = max(0, min(255, int(int(h[0:2],16)*f)))
    g = max(0, min(255, int(int(h[2:4],16)*f)))
    b = max(0, min(255, int(int(h[4:6],16)*f)))
    return f"#{r:02x}{g:02x}{b:02x}"

def _text_fg_for_bg(bg):
    h = bg.lstrip("#")
    r,g,b = int(h[0:2],16), int(h[2:4],16), int(h[4:6],16)
    lum = 0.299*r + 0.587*g + 0.114*b
    return "#111111" if lum > 140 else "#ffffff"

def _rating_fg(rating):
    if rating is None: return FG_WHITE
    return _text_fg_for_bg(rating_color(rating))

def open_in_explorer(path):
    if os.path.isfile(path):
        subprocess.Popen(f'explorer /select,"{path}"')
    elif os.path.isdir(path):
        subprocess.Popen(f'explorer "{path}"')

def _rating_sort_key(rel, unseen_first):
    """Sort key for rating-based sort. Returns (primary_order, name)."""
    base   = os.path.basename(rel)
    rating = get_rating_from_name(base)
    name   = strip_prefix(base).lower()
    # order: 5,4,3,2,1 then unrated, then 0
    # unseen_first=True:  truly unrated before "-" prefixed
    # unseen_first=False: "-" prefixed before truly unrated
    if rating is not None and rating > 0:
        primary = 5 - rating          # 0..4
    elif rating == 0:
        primary = 7
    elif is_unrated(base):            # no prefix at all
        primary = 5 if unseen_first else 6
    else:                             # has "-" prefix
        primary = 6 if unseen_first else 5
    return (primary, name)

def sort_files(files, folder, method):
    def fp(f): return os.path.join(folder, f)
    if method == "Name":
        return sorted(files, key=lambda f: sort_key_strip(os.path.basename(f)))
    elif method == "Rating (Unseen First)":
        return sorted(files, key=lambda f: _rating_sort_key(f, True))
    elif method == "Rating (Unseen Last)":
        return sorted(files, key=lambda f: _rating_sort_key(f, False))
    elif method == "Date Modified":
        return sorted(files, key=lambda f: os.path.getmtime(fp(f)))
    elif method == "Date Created":
        return sorted(files, key=lambda f: os.path.getctime(fp(f)))
    elif method == "File Size":
        return sorted(files, key=lambda f: os.path.getsize(fp(f)))
    elif method == "Random":
        out = list(files); random.shuffle(out); return out
    return files

def get_png_comment(filepath):
    result = []
    try:
        with open(filepath, "rb") as f:
            if f.read(8) != b'\x89PNG\r\n\x1a\n': return ""
            while True:
                hdr = f.read(8)
                if len(hdr) < 8: break
                length = struct.unpack(">I", hdr[:4])[0]
                ctype  = hdr[4:8]
                data   = f.read(length); f.read(4)
                if ctype == b'tEXt':
                    parts = data.split(b'\x00',1)
                    if len(parts)==2: result.append(parts[1].decode("latin-1","replace"))
                elif ctype == b'iTXt':
                    parts = data.split(b'\x00',1)
                    if len(parts)==2: result.append(parts[1].decode("utf-8","replace"))
                elif ctype == b'IEND': break
    except Exception: pass
    return " ".join(result)

# ── Tooltip ───────────────────────────────────────────────────────────────────

class Tooltip:
    def __init__(self, widget, text, delay=1000):
        self.widget = widget; self.text = text; self.delay = delay
        self._id = None; self._tip = None
        widget.bind("<Enter>",  self._schedule)
        widget.bind("<Leave>",  self._cancel)
        widget.bind("<Button>", self._cancel)

    def _schedule(self, e=None):
        self._cancel()
        self._id = self.widget.after(self.delay, self._show)

    def _cancel(self, e=None):
        if self._id: self.widget.after_cancel(self._id); self._id = None
        if self._tip:
            try: self._tip.destroy()
            except Exception: pass
            self._tip = None

    def _show(self):
        try:
            x = self.widget.winfo_rootx() + 20
            y = self.widget.winfo_rooty() + self.widget.winfo_height() + 4
            self._tip = tk.Toplevel(self.widget)
            self._tip.wm_overrideredirect(True)
            self._tip.wm_geometry(f"+{x}+{y}")
            tk.Label(self._tip, text=self.text, bg="#ffffcc", fg="#222222",
                     relief=tk.SOLID, borderwidth=1,
                     font=("Segoe UI",8), padx=6, pady=3).pack()
        except Exception: pass

def tip(widget, text):
    Tooltip(widget, text); return widget

